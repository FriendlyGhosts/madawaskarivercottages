                        )}
                      </div>
                    </div>
                  ))}
                </div>
                <div class="cal-legend mt-3">
                  <span class="cal-legend-item"><span class="cal-legend-dot cal-legend-avail"></span>Available</span>
                  <span class="cal-legend-item"><span class="cal-legend-dot cal-legend-book"></span>Booked</span>
