      </div>
    </div>
    <!-- Mobile: title left, links right -->
    <div class="flex md:hidden items-center justify-between">
      <div class="text-base tracking-[0.08em] uppercase leading-tight" style="font-family: 'Cormorant', serif; font-weight: 400; color: var(--color-accent)">
        Madawaska<br/>River Cottages
      </div>
      <div class="flex items-center gap-5 text-[10px] tracking-[0.14em] uppercase" style="color: var(--color-muted)">
        <a href="#cottages" class="py-2 transition-colors duration-300 hover:text-[var(--color-text)]">Cottages</a>
        <a href="#contact" class="py-2 transition-colors duration-300 hover:text-[var(--color-text)]">Book</a>
        <button class="mode-toggle text-base transition-all duration-300" style="color: var(--color-accent); background: none; border: none; padding: 8px 6px; margin: -8px -6px; touch-action: manipulation;" aria-label="Toggle night mode">☽</button>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden" id="hero">

    <!-- Rings canvas — always visible, adapts colour to day/night -->
    <div id="sun-rings-wrap" style="position:fixed;top:12%;right:14%;z-index:1;overflow:visible;pointer-events:none;width:90px;height:90px;">
      <canvas id="sun-rings-canvas" style="position:absolute;width:340px;height:340px;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;"></canvas>
    </div>

    <!-- Sun (day mode only) -->
    <div id="sun" style="position:fixed;top: 12%; right: 14%; z-index: 2;">
      <div style="width:90px;height:90px;border-radius:50%;background:#f5c842;opacity:0.5;box-shadow:0 0 40px 16px rgba(245,200,66,0.22),0 0 80px 40px rgba(245,200,66,0.09);"></div>
    </div>

    <!-- Moon (night mode only) -->
    <div id="moon" style="position:fixed;top: 12%; right: 14%; z-index: 2;">
      <div style="width: 90px; height: 90px; border-radius: 50%; background: radial-gradient(circle at 38% 38%, #fffde8, #f5e6b8); box-shadow: 0 0 40px 12px rgba(245,230,150,0.25), 0 0 90px 35px rgba(167,139,250,0.12); position: relative;">
        <div style="position:absolute;width:13px;height:13px;border-radius:50%;background:rgba(180,160,100,0.28);top:28%;left:54%;"></div>
        <div style="position:absolute;width:9px;height:9px;border-radius:50%;background:rgba(180,160,100,0.22);top:56%;left:28%;"></div>
        <div style="position:absolute;width:6px;height:6px;border-radius:50%;background:rgba(180,160,100,0.18);top:18%;left:22%;"></div>
        <div style="position:absolute;width:5px;height:5px;border-radius:50%;background:rgba(180,160,100,0.15);top:68%;left:60%;"></div>
      </div>
    </div>


    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <p class="reveal text-xs tracking-[0.35em] uppercase mb-8" style="color: var(--color-accent)">
        Griffith, Ontario · Madawaska River
      </p>
      <h1 class="reveal reveal-delay-1 text-5xl md:text-8xl lg:text-9xl font-light leading-[0.9] mb-6 md:mb-8" style="font-family: 'Cormorant', serif">
        Quiet mornings.<br/>
        The <em class="not-italic" style="color: var(--color-accent)">river</em><br/>
        at your door.
      </h1>
      <p class="reveal reveal-delay-2 text-sm md:text-lg max-w-lg mx-auto leading-relaxed mb-8 md:mb-12" style="color: var(--color-muted)">
        Four private cottages set along the banks of the Madawaska River. Quiet mornings, open skies, and nothing between you and the water.
      </p>
      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#cottages"
          class="px-10 py-4 text-xs tracking-[0.25em] uppercase transition-all duration-300 hover:opacity-90"
          style="background: var(--color-accent); color: var(--color-bg)"
          data-hover
        >
          View Cottages
        </a>
        <a
          href="#contact"
          class="px-10 py-4 text-xs tracking-[0.25em] uppercase border transition-all duration-300 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
          style="border-color: var(--color-border); color: var(--color-muted)"
          data-hover
