---
import Layout from '../layouts/Layout.astro';
// Build timestamp — remove once no longer needed for deploy checks
const buildVersion = new Date().toLocaleString('en-CA', {
  month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit',
  hour12: false, timeZone: 'America/Toronto'
});

// ─── iCal fetch + parse ───────────────────────────────────────────────────────

function parseIcalBookedDates(icsText: string): string[] {
  const dates = new Set<string>();
  const lines = icsText.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');
  let inEvent = false;
  let dtstart = '';
  let dtend = '';

  for (const line of lines) {
    const t = line.trim();
    if (t === 'BEGIN:VEVENT') {
      inEvent = true; dtstart = ''; dtend = '';
    } else if (t === 'END:VEVENT') {
      inEvent = false;
      if (dtstart && dtend) {
        let d = new Date(+dtstart.slice(0,4), +dtstart.slice(4,6)-1, +dtstart.slice(6,8));
        const end = new Date(+dtend.slice(0,4), +dtend.slice(4,6)-1, +dtend.slice(6,8));
        while (d < end) {
          dates.add(`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`);
          d.setDate(d.getDate() + 1);
        }
      }
    } else if (inEvent) {
      const ms = line.match(/^DTSTART(?:;[^:]+)?:(\d{8})/);
      const me = line.match(/^DTEND(?:;[^:]+)?:(\d{8})/);
      if (ms) dtstart = ms[1];
      if (me) dtend = me[1];
    }
  }
  return [...dates].sort();
}

async function fetchBookedDates(icalUrl: string | null): Promise<string[]> {
  if (!icalUrl) return [];
  try {
    const res = await fetch(icalUrl, { headers: { 'User-Agent': 'Mozilla/5.0' } });
    if (!res.ok) return [];
    return parseIcalBookedDates(await res.text());
  } catch { return []; }
}

// Merge booked dates from a primary + any number of extra iCal feeds.
// Used when a cottage is double-listed across channels (Airbnb + Cottages in Canada,
// VRBO, Booking.com, etc.) — we union all blocked dates so the on-site calendar is
// always accurate even if one feed lags behind another.
async function fetchBookedDatesMulti(urls: (string | null | undefined)[]): Promise<string[]> {
  const clean = urls.filter((u): u is string => !!u);
  if (clean.length === 0) return [];
  const results = await Promise.all(clean.map(fetchBookedDates));
  return [...new Set(results.flat())].sort();
}

// ─── Calendar data builder ────────────────────────────────────────────────────

const MONTH_NAMES = ['January','February','March','April','May','June',
                     'July','August','September','October','November','December'];
const DAY_LABELS = ['Su','Mo','Tu','We','Th','Fr','Sa'];

type CalCell = { day: number; ds: string; booked: boolean; today: boolean; past: boolean } | null;

function buildCalendar(bookedDates: string[], numMonths = 2) {
  const now = new Date();
  const todayStr = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
  const booked = new Set(bookedDates);

  return Array.from({ length: numMonths }, (_, m) => {
    const ref = new Date(now.getFullYear(), now.getMonth() + m, 1);
    const year = ref.getFullYear();
    const month = ref.getMonth();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const firstDow = ref.getDay();

    const cells: CalCell[] = [
      ...Array.from<null>({ length: firstDow }, () => null),
      ...Array.from({ length: daysInMonth }, (_, i) => {
        const day = i + 1;
        const ds = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
        return { day, ds, booked: booked.has(ds), today: false, past: ds < todayStr };
      }),
    ];
    while (cells.length % 7 !== 0) cells.push(null);
    return { year, month, name: MONTH_NAMES[month], cells };
  });
}

// ─── Property data + fetch ────────────────────────────────────────────────────

const cottageDefs = [
