  <script is:inline>
    function applyFont(font) {
      var val = "'" + font + "', serif";
      document.querySelectorAll('h1,h2,h3,h4').forEach(function(el) {
        el.style.setProperty('font-family', val, 'important');
      });
      document.querySelectorAll('[style]').forEach(function(el) {
        if (el.getAttribute('style').indexOf('serif') !== -1) {
          el.style.setProperty('font-family', val, 'important');
        }
      });
    }
    document.querySelectorAll('input[name="font-pick"]').forEach(function(r) {
      r.addEventListener('change', function(e) { applyFont(e.target.value); });
    });
  </script>

  <script>
    // ── Sun: triple-click → toggle zen mode ──────────────────────────────────
    // Entering zen: triggers the solar explosion + sky reddening + aurora
    // Exiting zen:  clears sky + aurora, restores normal view
    // On mobile the sun IIFE exits early so triggerSunExplosion/clearSkyEffects
    // are never defined — the optional-chain calls below safely no-op.
    let _sc = 0, _st: ReturnType<typeof setTimeout> | null = null;
    function _sunClick() {
      _sc++;
      if (_st) clearTimeout(_st);
      if (_sc >= 3) {
        _sc = 0;
        const entering = !document.documentElement.classList.contains('zen-mode');
        document.documentElement.classList.toggle('zen-mode');
        if (entering) {
          (window as any).triggerSunExplosion?.();
        } else {
          (window as any).clearSkyEffects?.();
        }
      } else {
        _st = setTimeout(() => { _sc = 0; }, 500);
      }
    }
    document.getElementById('sun')?.addEventListener('click', _sunClick);

    // ── Moon: triple-click → toggle zen mode (clears effects on exit) ────────
    let _zc = 0, _zt: ReturnType<typeof setTimeout> | null = null;
    function _zen() {
      _zc++;
      if (_zt) clearTimeout(_zt);
      if (_zc >= 3) {
        _zc = 0;
        const exiting = document.documentElement.classList.contains('zen-mode');
        document.documentElement.classList.toggle('zen-mode');
        if (exiting) (window as any).clearSkyEffects?.();
      } else {
        _zt = setTimeout(() => { _zc = 0; }, 500);
      }
    }
    document.getElementById('moon')?.addEventListener('click', _zen);
  </script>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const errorEl = document.getElementById('contact-error') as HTMLElement | null;
    const successEl = document.getElementById('contact-success') as HTMLElement | null;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !errorEl || !successEl) return;

      errorEl.style.display = 'none';
      submitBtn.textContent = 'Sending…';
      submitBtn.disabled = true;

      const data = Object.fromEntries(new FormData(form));

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        // Parse JSON safely — server might return HTML on unexpected errors
        let json: Record<string, unknown> = {};
        try { json = await res.json(); } catch { /* not JSON */ }

        if (!res.ok || json.error) {
          errorEl.textContent = (json.error as string) || `Error ${res.status}. Please email us at madawaskarivercottages@gmail.com`;
          errorEl.style.display = 'block';
          submitBtn.textContent = 'Send Enquiry';
          submitBtn.disabled = false;
        } else {
          form.style.display = 'none';
          successEl.style.display = 'block';
        }
      } catch (err) {
        errorEl.textContent = `Could not reach the server. Please email us at madawaskarivercottages@gmail.com`;
        errorEl.style.display = 'block';
        submitBtn.textContent = 'Send Enquiry';
        submitBtn.disabled = false;
      }
    });
  </script>

</Layout>

<style>
  @keyframes scrollDrop {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
  nav {
    background: linear-gradient(to bottom, rgba(242,236,224,0.97) 60%, transparent);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  html.night nav {
    background: linear-gradient(to bottom, rgba(24,20,16,0.97) 60%, transparent);
  }
  nav.nav-hidden {
    transform: translateY(-100%);
  }

  /* ── Mobile: send sun/moon decorations behind page content ────────────────
     They're decorative-only on mobile (zen-mode click handlers and sun-rings
     IIFE already early-exit when navigator.maxTouchPoints > 0). The desktop
     z-index:2 puts them above section content, which gets in the way of
     scrolling/reading on a narrow viewport. */
  @media (max-width: 767px) {
    #sun, #moon, #sun-rings-wrap {
      z-index: -1 !important;
      pointer-events: none !important;
    }
  }

  /* ── Availability calendar ── */
  .cal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  @media (max-width: 480px) {
    .cal-grid { grid-template-columns: 1fr; }
  }
  .cal-month-name {
    font-family: 'Cormorant', serif;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .cal-days-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
