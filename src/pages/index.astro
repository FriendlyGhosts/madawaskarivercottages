const cottages = cottageDefs.map((c, i) => ({ ...c, calMonths: buildCalendar(allDates[i]) }));
const treehouse = { ...treehouseDef, calMonths: buildCalendar(allDates[icalUrls.length - 1]) };

const amenities = [
