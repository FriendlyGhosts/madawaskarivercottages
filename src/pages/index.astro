  }
  .cal-legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .cal-legend-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 1px;
  }
  .cal-legend-avail { background: var(--color-text); opacity: 0.15; border: 1px solid var(--color-border); }
  .cal-legend-book  { background: var(--color-border); }
</style>
