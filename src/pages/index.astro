          <select class="w-full px-4 py-3 text-sm border outline-none focus:border-[var(--color-accent)] transition-colors duration-300 appearance-none" style="background: var(--color-surface); border-color: var(--color-border); color: var(--color-text)">
            <option value="">Select a cabin</option>
            <option>Whitetail Lodge (117) — Sleeps 4</option>
            <option>Owl's Nest (143) — Sleeps 4</option>
            <option>Cedarwood Cabin (157) — Sleeps 4</option>
            <option>Lazy Bear Lodge (165) — Sleeps 6</option>
            <option>The Treehouse — Sleeps 2</option>
            <option>Not sure yet</option>
          </select>
        </div>
        <div>
          <label class="block text-xs tracking-[0.15em] uppercase mb-2" style="color: var(--color-muted)">Message & Dates</label>
          <textarea rows="4" class="w-full px-4 py-3 text-sm bg-transparent border outline-none focus:border-[var(--color-accent)] transition-colors duration-300 resize-none" style="border-color: var(--color-border); color: var(--color-text)" placeholder="Tell us your preferred dates and anything else..."></textarea>
        </div>
        <button type="submit" class="w-full py-4 text-xs tracking-[0.25em] uppercase transition-all duration-300 hover:opacity-90" style="background: var(--color-accent); color: var(--color-bg)" data-hover>
          Send Enquiry
        </button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-12 px-6 text-center" style="border-top: 1px solid var(--color-border)">
    <p class="text-xs tracking-[0.2em] uppercase mb-2" style="color: var(--color-accent)">Madawaska River Cottages</p>
    <p class="text-xs" style="color: var(--color-muted)">Griffith, Ontario · On the Madawaska River</p>
  </footer>

  <!-- ⚠️ TEMP: Font tester (hidden) -->
  <div style="display:none;position:fixed;bottom:20px;right:20px;z-index:9999;background:var(--color-surface);border:1px solid var(--color-border);padding:16px 20px;font-family:'Inter',sans-serif;font-size:11px;box-shadow:0 4px 24px rgba(0,0,0,0.15);min-width:200px;">
    <div style="color:var(--color-muted);text-transform:uppercase;letter-spacing:0.18em;margin-bottom:12px;font-size:10px;">Font Tester</div>
    <div style="display:flex;flex-direction:column;gap:8px;">
      {[
        { name: 'Josefin Slab',      weight: '400' },
        { name: 'Cinzel Decorative', weight: '400' },
        { name: 'Uncial Antiqua',    weight: '400' },
        { name: 'Pirata One',        weight: '400' },
        { name: 'Fondamento',        weight: '400' },
        { name: 'Metamorphous',      weight: '400' },
        { name: 'Caesar Dressing',   weight: '400' },
        { name: 'Mystery Quest',     weight: '400' },
        { name: 'Cormorant',          weight: '300' },
        { name: 'Cormorant Unicase',  weight: '300' },
        { name: 'Bodoni Moda',        weight: '400' },
        { name: 'Poiret One',        weight: '400' },
      ].map(f => (
        <label style="display:flex;align-items:center;gap:10px;cursor:pointer;">
          <input type="radio" name="font-pick" value={f.name} checked={f.name === 'Josefin Slab'} style="accent-color:var(--color-accent);flex-shrink:0;" />
          <span style={`font-family:'${f.name}',serif;font-size:16px;font-weight:${f.weight};color:var(--color-text);`}>{f.name}</span>
        </label>
      ))}
    </div>
  </div>
  <script is:inline>
    function applyFont(font) {
      var val = "'" + font + "', serif";
      document.querySelectorAll('h1,h2,h3,h4').forEach(function(el) {
        el.style.setProperty('font-family', val, 'important');
      });
      document.querySelectorAll('[style]').forEach(function(el) {
        if (el.getAttribute('style').indexOf('serif') !== -1) {
          el.style.setProperty('font-family', val, 'important');
        }
      });
    }
    document.querySelectorAll('input[name="font-pick"]').forEach(function(r) {
      r.addEventListener('change', function(e) { applyFont(e.target.value); });
    });
  </script>

</Layout>

