---
import Layout from '../layouts/Layout.astro';

const cottages = [
  {
    number: '117',
    name: 'Whitetail Lodge',
    tagline: 'Intimate riverside escape',
    sleeps: 4,
    bedDetail: '1 double + 1 queen · 2 bed · 1 bath',
    pets: true,
    photo: '/images/cottages/cozy-riverfront-1.jpg',
    airbnbId: '895861420839792739',
    description: 'A private two-bedroom cabin on the Madawaska. Hike the Uplands Trail, boulder at Calabogie, kayak the rapids, or spend a lazy afternoon paddleboarding. End your day at the fire pit under the stars.',
  },
  {
    number: '143',
    name: "Owl's Nest",
    tagline: 'The riverside classic',
    sleeps: 4,
    bedDetail: '2 bedrooms · 2 beds · 1 bath',
    pets: false,
    photo: '/images/cottages/magical-wintertime-1.jpg',
    airbnbId: '1037163450739528690',
    description: 'Nestled on 2 secluded acres right on the river. Thousands of acres of wild, rolling landscape and hidden lakes wait to be discovered — and a smoldering fire will be waiting for your return.',
  },
  {
    number: '157',
    name: 'Cedarwood Cabin',
    tagline: 'Warmth and seclusion',
    sleeps: 4,
    bedDetail: '2 bedrooms · 1 bath',
    pets: false,
    photo: '/images/cottages/tucked-away-1.jpg',
    airbnbId: '679589509313140703',
    description: 'Tucked away in the forest, right on the Madawaska. Private river access for paddleboarding, kayaking, and canoeing. Early risers catch the morning mist from the dock with a cup of tea.',
  },
  {
    number: '165',
    name: 'Lazy Bear Lodge',
    tagline: 'The group retreat',
    sleeps: 6,
    bedDetail: '1 queen, 1 double + pull-out sofa',
    pets: true,
    photo: null,
    airbnbId: null,
    description: 'Spacious and comfortable with room for the whole crew. A full kitchen, large living area, fire pit, and private dock on the Madawaska River.',
  },
];

const treehouse = {
  name: 'The Treehouse',
  tagline: 'Lost in the canopy',
  sleeps: 2,
  bedDetail: '1 bedroom',
  pets: false,
  photos: [
    '/images/cottages/cabin-heaven-1.jpg',
    '/images/cottages/cabin-heaven-2.jpg',
    '/images/cottages/cabin-heaven-3.jpg',
    '/images/cottages/cabin-heaven-4.jpg',
  ],
  airbnbId: '1042917519190055212',
  description: 'Tucked into the forest, 650 m from the road along a rustic trail — this one isn\'t on the river. It\'s something different. No neighbours, no noise, just trees and sky. Reconnect with nature at this unforgettable escape.',
};

const amenities = [
  { icon: '◈', label: 'Private Riverfront Dock' },
  { icon: '◈', label: 'Firepit & BBQ' },
  { icon: '◈', label: 'Fully Equipped Kitchen' },
  { icon: '◈', label: 'Canoe or Kayak Included' },
  { icon: '◈', label: 'Deck with Patio Table' },
  { icon: '◈', label: '2 Acres of Privacy' },
  { icon: '◈', label: 'Life Jackets Provided' },
  { icon: '◈', label: 'Pet Friendly Options' },
];
---

<Layout>
  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-5 py-3 md:py-4">
    <!-- Desktop: stacked centered layout -->
    <div class="hidden md:flex flex-col items-center gap-2">
      <div class="text-3xl tracking-[0.12em] uppercase" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: var(--color-accent)">
        Madawaska River Cottages
      </div>
      <div class="flex items-center gap-8 text-xs tracking-[0.18em] uppercase" style="color: var(--color-muted)">
        <a href="#cottages" class="hover:text-[var(--color-text)] transition-colors duration-300">Cottages</a>
        <a href="#treehouse" class="hover:text-[var(--color-text)] transition-colors duration-300">Treehouse</a>
        <a href="#amenities" class="hover:text-[var(--color-text)] transition-colors duration-300">Amenities</a>
        <a href="#location" class="hover:text-[var(--color-text)] transition-colors duration-300">Location</a>
        <a href="#contact" class="hover:text-[var(--color-text)] transition-colors duration-300">Book</a>
        <button id="mode-toggle" class="text-lg transition-all duration-300 hover:scale-110 hover:opacity-80" style="color: var(--color-accent); background: none; border: none; padding: 2px 6px;" data-hover aria-label="Toggle night mode">☽</button>
      </div>
    </div>
    <!-- Mobile: title left, links right -->
    <div class="flex md:hidden items-center justify-between">
      <div class="text-base tracking-[0.08em] uppercase leading-tight" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: var(--color-accent)">
        Madawaska<br/>River Cottages
      </div>
      <div class="flex items-center gap-4 text-[10px] tracking-[0.14em] uppercase" style="color: var(--color-muted)">
        <a href="#cottages" class="hover:text-[var(--color-text)] transition-colors duration-300">Cottages</a>
        <a href="#contact" class="hover:text-[var(--color-text)] transition-colors duration-300">Book</a>
        <button id="mode-toggle" class="text-base transition-all duration-300" style="color: var(--color-accent); background: none; border: none; padding: 2px 4px;" data-hover aria-label="Toggle night mode">☽</button>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden" id="hero">

    <!-- Moon (night mode only) -->
    <div id="moon" class="absolute" style="top: 12%; right: 14%; z-index: 1;">
      <div style="width: 90px; height: 90px; border-radius: 50%; background: radial-gradient(circle at 38% 38%, #fffde8, #f5e6b8); box-shadow: 0 0 40px 12px rgba(245,230,150,0.25), 0 0 90px 35px rgba(167,139,250,0.12); position: relative;">
        <div style="position:absolute;width:13px;height:13px;border-radius:50%;background:rgba(180,160,100,0.28);top:28%;left:54%;"></div>
        <div style="position:absolute;width:9px;height:9px;border-radius:50%;background:rgba(180,160,100,0.22);top:56%;left:28%;"></div>
        <div style="position:absolute;width:6px;height:6px;border-radius:50%;background:rgba(180,160,100,0.18);top:18%;left:22%;"></div>
        <div style="position:absolute;width:5px;height:5px;border-radius:50%;background:rgba(180,160,100,0.15);top:68%;left:60%;"></div>
      </div>
    </div>

    <div class="absolute right-12 top-1/2 -translate-y-1/2 hidden lg:block">
      <div class="text-[180px] font-thin leading-none select-none" style="font-family: 'Cormorant Garamond', serif; color: var(--color-watermark)">MRC</div>
    </div>

    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <p class="reveal text-xs tracking-[0.35em] uppercase mb-8" style="color: var(--color-accent)">
        Griffith, Ontario · Madawaska River
      </p>
      <h1 class="reveal reveal-delay-1 text-6xl md:text-8xl lg:text-9xl font-light leading-[0.9] mb-8" style="font-family: 'Cormorant Garamond', serif">
        Where the<br/>
        <em class="not-italic" style="color: var(--color-accent)">river</em> calls<br/>
        you home
      </h1>
      <p class="reveal reveal-delay-2 text-base md:text-lg max-w-lg mx-auto leading-relaxed mb-12" style="color: var(--color-muted)">
        Four private cottages set along the banks of the Madawaska River. Quiet mornings, open skies, and nothing between you and the water.
      </p>
      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#cottages"
          class="px-10 py-4 text-xs tracking-[0.25em] uppercase transition-all duration-300 hover:opacity-90"
          style="background: var(--color-accent); color: var(--color-bg)"
          data-hover
        >
          View Cottages
        </a>
        <a
          href="#contact"
          class="px-10 py-4 text-xs tracking-[0.25em] uppercase border transition-all duration-300 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
          style="border-color: var(--color-border); color: var(--color-muted)"
          data-hover
        >
          Enquire Now
        </a>
      </div>
    </div>

    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
      <span class="text-xs tracking-[0.2em] uppercase" style="color: var(--color-muted)">Scroll</span>
      <div class="w-px h-12 overflow-hidden" style="background: var(--color-border)">
        <div class="w-full h-1/2" style="background: var(--color-accent); animation: scrollDrop 1.8s ease-in-out infinite"></div>
      </div>
    </div>
  </section>

  <!-- COTTAGES -->
  <section id="cottages" class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-20">
        <p class="reveal text-xs tracking-[0.3em] uppercase mb-4" style="color: var(--color-accent)">The Properties</p>
        <h2 class="reveal reveal-delay-1 text-5xl md:text-6xl font-light" style="font-family: 'Cormorant Garamond', serif">Four Cottages.<br/>One River.</h2>
        <div class="reveal reveal-delay-2 divider mt-6 mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {cottages.map((c, i) => (
          <div
            class={`reveal reveal-delay-${i + 1} group relative overflow-hidden border transition-all duration-500 hover:border-[var(--color-accent-dim)]`}
            style="background: var(--color-surface); border-color: var(--color-border)"
            data-hover
          >
            <div class="relative overflow-hidden" style="height: 260px; background: var(--gradient-card)">
              {c.photo ? (
                <img
                  src={c.photo}
                  alt={c.name}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center">
                  <span class="text-[120px] font-thin select-none transition-transform duration-700 group-hover:scale-110" style="color: rgba(0,175,192,0.20); font-family: 'Cormorant Garamond', serif">{c.number}</span>
                </div>
              )}
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(0,0,0,0.45), transparent)"></div>
              {c.airbnbId && (
                <div class="absolute bottom-4 left-6 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-2 group-hover:translate-y-0">
                  <a href={`https://www.airbnb.ca/rooms/${c.airbnbId}`} target="_blank" rel="noopener" class="text-xs tracking-[0.2em] uppercase" style="color: #fff" data-hover>Book on Airbnb →</a>
                </div>
              )}
            </div>
            <div class="p-8">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h3 class="text-2xl font-light" style="font-family: 'Cormorant Garamond', serif">{c.name}</h3>
                  <p class="text-xs tracking-[0.15em] uppercase mt-1" style="color: var(--color-accent)">{c.tagline}</p>
                </div>
                <div class="text-right text-xs" style="color: var(--color-muted)">
                  <div>Sleeps {c.sleeps}</div>
                  <div>{c.bedDetail}</div>
                  {c.pets && <div class="mt-1" style="color: var(--color-accent)">Pet friendly</div>}
                </div>
              </div>
              <p class="text-sm leading-relaxed mt-4" style="color: var(--color-muted)">{c.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TREEHOUSE -->
  <section id="treehouse" class="py-32 px-6" style="background: var(--color-surface)">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="reveal order-2 md:order-1 grid grid-cols-2 gap-3">
          {treehouse.photos.map((src, i) => (
            <div class={`overflow-hidden ${i === 0 ? 'col-span-2' : ''}`} style={`height: ${i === 0 ? '260px' : '140px'}`}>
              <img src={src} alt={`The Treehouse ${i + 1}`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
            </div>
          ))}
        </div>
        <div class="order-1 md:order-2">
          <p class="reveal text-xs tracking-[0.3em] uppercase mb-4" style="color: var(--color-accent)">Something Different</p>
          <h2 class="reveal reveal-delay-1 text-5xl font-light mb-2" style="font-family: 'Cormorant Garamond', serif">{treehouse.name}</h2>
          <p class="reveal reveal-delay-1 text-xs tracking-[0.15em] uppercase mb-6" style="color: var(--color-accent)">{treehouse.tagline}</p>
          <div class="reveal reveal-delay-2 divider mb-8"></div>
          <p class="reveal reveal-delay-2 text-sm leading-relaxed mb-8" style="color: var(--color-muted)">{treehouse.description}</p>
          <div class="reveal reveal-delay-3 flex gap-8 text-xs mb-10" style="color: var(--color-muted)">
            <div><span style="color: var(--color-accent)">Sleeps</span><br/>{treehouse.sleeps}</div>
            <div><span style="color: var(--color-accent)">Beds</span><br/>{treehouse.bedDetail}</div>
            <div><span style="color: var(--color-accent)">Pets</span><br/>No</div>
          </div>
          <div class="reveal reveal-delay-3">
            <a
              href={`https://www.airbnb.ca/rooms/${treehouse.airbnbId}`}
              target="_blank"
              rel="noopener"
              class="inline-block px-10 py-4 text-xs tracking-[0.25em] uppercase transition-all duration-300 hover:opacity-90"
              style="background: var(--color-accent); color: var(--color-bg)"
              data-hover
            >
              Book on Airbnb
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AMENITIES -->
  <section id="amenities" class="py-32 px-6" style="background: var(--color-surface)">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-20">
        <p class="reveal text-xs tracking-[0.3em] uppercase mb-4" style="color: var(--color-accent)">What's Included</p>
        <h2 class="reveal reveal-delay-1 text-5xl md:text-6xl font-light" style="font-family: 'Cormorant Garamond', serif">Everything you need.<br/>Nothing you don't.</h2>
        <div class="reveal reveal-delay-2 divider mt-6 mx-auto"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px" style="background: var(--color-border)">
        {amenities.map((a, i) => (
          <div
            class={`reveal reveal-delay-${(i % 4) + 1} flex flex-col items-center justify-center py-10 px-6 text-center transition-colors duration-300 hover:bg-[var(--color-green)]`}
            style="background: var(--color-surface)"
            data-hover
          >
            <span class="text-2xl mb-4" style="color: var(--color-accent)">{a.icon}</span>
            <span class="text-xs tracking-[0.15em] uppercase leading-relaxed" style="color: var(--color-muted)">{a.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCATION -->
  <section id="location" class="py-32 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="reveal text-xs tracking-[0.3em] uppercase mb-4" style="color: var(--color-accent)">Find Us</p>
          <h2 class="reveal reveal-delay-1 text-5xl font-light mb-6" style="font-family: 'Cormorant Garamond', serif">Deep in the<br/>Ottawa Valley</h2>
          <div class="reveal reveal-delay-2 divider mb-8"></div>
          <p class="reveal reveal-delay-2 text-sm leading-relaxed mb-6" style="color: var(--color-muted)">
            Nestled on Harrison Trail in Griffith, Ontario — within Madawaska Provincial Park. Just 90 minutes from Ottawa and close enough to civilization, yet worlds away from it.
          </p>
          <ul class="reveal reveal-delay-3 space-y-3 text-sm" style="color: var(--color-muted)">
            <li class="flex gap-3"><span style="color: var(--color-accent)">—</span> 90 min from Ottawa</li>
            <li class="flex gap-3"><span style="color: var(--color-accent)">—</span> 40 min from Calabogie Ski Resort</li>
            <li class="flex gap-3"><span style="color: var(--color-accent)">—</span> 90 min from Algonquin Park</li>
            <li class="flex gap-3"><span style="color: var(--color-accent)">—</span> General store, pub & LCBO in Griffith</li>
            <li class="flex gap-3"><span style="color: var(--color-accent)">—</span> Boat launch 10 min away — Centennial Lake</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-2 relative overflow-hidden" style="height: 400px; background: var(--gradient-map); border: 1px solid var(--color-border)">
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color: var(--color-border)">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span class="text-xs tracking-[0.2em] uppercase" style="color: var(--color-muted)">Griffith, Ontario</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="py-32 px-6" style="background: var(--color-surface)">
    <div class="max-w-xl mx-auto text-center">
      <p class="reveal text-xs tracking-[0.3em] uppercase mb-4" style="color: var(--color-accent)">Reserve Your Stay</p>
      <h2 class="reveal reveal-delay-1 text-5xl md:text-6xl font-light mb-4" style="font-family: 'Cormorant Garamond', serif">Ready to escape?</h2>
      <div class="reveal reveal-delay-2 divider mx-auto mb-8"></div>
      <p class="reveal reveal-delay-2 text-sm leading-relaxed mb-4" style="color: var(--color-muted)">
        Tell us which cabin interests you, your preferred dates, and we'll get back to you shortly. Minimum stay is one week. Check-in 3 pm · Check-out 11 am.
      </p>
      <p class="reveal reveal-delay-2 text-xs mb-12" style="color: var(--color-muted)">
        50% deposit to confirm · $300 refundable damage deposit · Pet fee $50/pet · Rates exclude taxes
      </p>
      <form class="reveal reveal-delay-3 space-y-4 text-left" id="contact-form">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs tracking-[0.15em] uppercase mb-2" style="color: var(--color-muted)">First Name</label>
            <input type="text" class="w-full px-4 py-3 text-sm bg-transparent border outline-none focus:border-[var(--color-accent)] transition-colors duration-300" style="border-color: var(--color-border); color: var(--color-text)" />
          </div>
          <div>
            <label class="block text-xs tracking-[0.15em] uppercase mb-2" style="color: var(--color-muted)">Last Name</label>
            <input type="text" class="w-full px-4 py-3 text-sm bg-transparent border outline-none focus:border-[var(--color-accent)] transition-colors duration-300" style="border-color: var(--color-border); color: var(--color-text)" />
          </div>
        </div>
        <div>
          <label class="block text-xs tracking-[0.15em] uppercase mb-2" style="color: var(--color-muted)">Email</label>
          <input type="email" class="w-full px-4 py-3 text-sm bg-transparent border outline-none focus:border-[var(--color-accent)] transition-colors duration-300" style="border-color: var(--color-border); color: var(--color-text)" />
        </div>
        <div>
          <label class="block text-xs tracking-[0.15em] uppercase mb-2" style="color: var(--color-muted)">Cabin</label>
          <select class="w-full px-4 py-3 text-sm border outline-none focus:border-[var(--color-accent)] transition-colors duration-300 appearance-none" style="background: var(--color-surface); border-color: var(--color-border); color: var(--color-text)">
            <option value="">Select a cabin</option>
            <option>Whitetail Lodge (117) — Sleeps 4</option>
            <option>Owl's Nest (143) — Sleeps 4</option>
            <option>Cedarwood Cabin (157) — Sleeps 4</option>
            <option>Lazy Bear Lodge (165) — Sleeps 6</option>
            <option>The Treehouse — Sleeps 2</option>
            <option>Not sure yet</option>
          </select>
        </div>
        <div>
          <label class="block text-xs tracking-[0.15em] uppercase mb-2" style="color: var(--color-muted)">Message & Dates</label>
          <textarea rows="4" class="w-full px-4 py-3 text-sm bg-transparent border outline-none focus:border-[var(--color-accent)] transition-colors duration-300 resize-none" style="border-color: var(--color-border); color: var(--color-text)" placeholder="Tell us your preferred dates and anything else..."></textarea>
        </div>
        <button type="submit" class="w-full py-4 text-xs tracking-[0.25em] uppercase transition-all duration-300 hover:opacity-90" style="background: var(--color-accent); color: var(--color-bg)" data-hover>
          Send Enquiry
        </button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-12 px-6 text-center" style="border-top: 1px solid var(--color-border)">
    <p class="text-xs tracking-[0.2em] uppercase mb-2" style="color: var(--color-accent)">Madawaska River Cottages</p>
    <p class="text-xs" style="color: var(--color-muted)">Griffith, Ontario · On the Madawaska River</p>
  </footer>
</Layout>

<style>
  @keyframes scrollDrop {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
  nav {
    background: linear-gradient(to bottom, rgba(242,236,224,0.97) 60%, transparent);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  html.night nav {
    background: linear-gradient(to bottom, rgba(24,20,16,0.97) 60%, transparent);
  }
  nav.nav-hidden {
    transform: translateY(-100%);
  }
</style>
