      </div>

      <!-- Calculator panel — all rows always visible to prevent layout shift -->
      <div id="calc-panel">
        <div class="flex items-center justify-between mb-5">
          <div class="text-2xl font-light" style="font-family:'Cormorant',serif; color:var(--color-text)">
            From&ensp;<span style="color:var(--color-accent)">${rate}</span>
            <span class="text-sm" style="font-family:'Inter',sans-serif; color:var(--color-muted)"> / night</span>
          </div>
          <button id="calc-clear" class="calc-hidden" style="font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-muted); background:none; border:none; cursor:pointer; text-decoration:underline; text-underline-offset:3px;">
            Clear dates
          </button>
        </div>

        <div class="calc-row">
          <span class="calc-label">Check-in</span>
          <span class="calc-value" id="calc-checkin" style="color:var(--color-muted); font-style:italic;">Select a date below</span>
        </div>
        <div class="calc-row">
          <span class="calc-label">Check-out</span>
          <span class="calc-value" id="calc-checkout" style="color:var(--color-muted);">—</span>
        </div>
        <div class="calc-row">
          <span class="calc-label">Duration</span>
          <span class="calc-value" id="calc-nights" style="color:var(--color-muted);">—</span>
        </div>
        <!-- Pet counter — always in DOM; display:none hides it on non-pet properties -->
        <div class="calc-row" id="pet-row" style={pets ? '' : 'display:none'}>
          <span class="calc-label">
            Pets
            <span style="font-size:10px; margin-left:5px; opacity:0.7;">($50 / pet · max 3)</span>
          </span>
          <div style="display:flex; align-items:center; gap:14px;">
            <button class="pet-btn" id="pet-dec" disabled aria-label="Remove pet">−</button>
            <span id="pet-count" style="font-size:13px; color:var(--color-text); min-width:1ch; text-align:center;">0</span>
            <button class="pet-btn" id="pet-inc" aria-label="Add pet">+</button>
          </div>
        </div>
        <!-- Pet fee — visibility:hidden keeps height stable; display:none on non-pet pages -->
        <div class="calc-row calc-hidden" id="pet-fee-row" style={pets ? '' : 'display:none'}>
          <span class="calc-label">Pet fee</span>
          <span class="calc-value" id="calc-pet-fee">—</span>
        </div>

        <div class="calc-row" id="calc-total-row">
          <span class="calc-label" style="font-weight:500">Estimated total</span>
          <span class="calc-value" id="calc-total" style="color:var(--color-muted);">—</span>
        </div>
        <p id="calc-footnote" class="calc-hidden" style="font-size:10px; color:var(--color-muted); margin-top:10px; letter-spacing:0.06em;">
          {pets
            ? 'Minimum 1-week stay · $50/pet fee · Rates exclude taxes · 50% deposit to confirm'
            : 'Minimum 1-week stay · Rates exclude taxes · 50% deposit to confirm'
          }
        </p>
        <!-- "Request These Dates" button — slides up when both dates are chosen -->
        <div id="enquire-btn-wrap">
          <button id="enquire-btn" data-hover>Request These Dates →</button>
        </div>
      </div>

      <!-- 6-month calendar -->
      <div class="cal-grid-full" id="cal-grid">
        {calMonths.map(mon => (
          <div class="cal-month">
            <div class="cal-month-name">{mon.name} {mon.year}</div>
            <div class="cal-days-grid">
              {DAY_LABELS.map(d => <div class="cal-dow">{d}</div>)}
              {mon.cells.map(cell => cell === null
                ? <div></div>
                : <div
                    class={`cal-day${cell.booked ? ' cal-booked' : ''}${cell.past ? ' cal-past' : ''}`}
                    data-date={cell.ds}
                    data-booked={cell.booked ? '1' : '0'}
                    data-past={cell.past ? '1' : '0'}
                  >{cell.day}</div>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="cal-legend mt-8">
        <span class="cal-legend-item">
          <span class="cal-legend-dot" style="background:var(--color-accent)"></span>Available
        </span>
        <span class="cal-legend-item">
          <span class="cal-legend-dot" style="background:var(--color-muted);opacity:0.5"></span>Booked
        </span>
        <span class="cal-legend-item">
          <span class="cal-legend-dot" style="background:var(--color-accent);opacity:0.6"></span>Selected
        </span>
      </div>

      <!-- ── INLINE ENQUIRY FORM — revealed by "Request These Dates" ─────────── -->
      <div id="enquiry-section">
        <div style="padding-top:48px;">
          <div class="divider" style="margin-bottom:32px;"></div>
          <p class="text-xs tracking-[0.3em] uppercase mb-2" style="color:var(--color-accent)">Send an Enquiry</p>
          <h2 class="text-3xl md:text-4xl font-light mb-10" style="font-family:'Cormorant',serif">Request These Dates</h2>

          <!-- Success state -->
          <div id="enq-success" style="display:none; padding:28px; background:rgba(46,107,138,0.07); border:1px solid var(--color-border); text-align:center; margin-bottom:24px;">
            <p style="font-size:13px; color:var(--color-accent); letter-spacing:0.06em; line-height:1.8;" id="enq-success-msg"></p>
          </div>

          <!-- Error state -->
          <div id="enq-error" style="display:none; padding:14px 16px; background:rgba(180,50,50,0.06); border:1px solid rgba(180,50,50,0.22); margin-bottom:20px;">
            <p style="font-size:12px; color:#b83232; letter-spacing:0.04em;" id="enq-error-msg"></p>
          </div>

          <form id="enq-form" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label style="font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-muted); display:block; margin-bottom:6px;">First name *</label>
                <input type="text" name="firstName" autocomplete="given-name" required />
              </div>
              <div>
                <label style="font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-muted); display:block; margin-bottom:6px;">Last name</label>
                <input type="text" name="lastName" autocomplete="family-name" />
              </div>
            </div>
            <div class="mb-4">
              <label style="font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-muted); display:block; margin-bottom:6px;">Email address *</label>
              <input type="email" name="email" autocomplete="email" required />
            </div>
            <div class="mb-6">
              <label style="font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-muted); display:block; margin-bottom:6px;">Message *</label>
              <textarea name="message" rows="6" id="enq-message" required></textarea>
            </div>
            <button type="submit" id="enq-submit" data-hover>Send Enquiry</button>
            <p style="font-size:10px; color:var(--color-muted); letter-spacing:0.06em; margin-top:12px; text-align:center;">
              We typically reply within 24 hours.
            </p>
          </form>
        </div>
      </div>
    </div>

    <!-- ── BOOK CTA ─────────────────────────────────────────────────────────── -->
    <div class="text-center pt-10" style="border-top: 1px solid var(--color-border)">
      <p class="text-xs tracking-[0.3em] uppercase mb-8" style="color: var(--color-accent)">Ready to book?</p>
      {airbnbId ? (
        <a
          href={`https://www.airbnb.ca/rooms/${airbnbId}`}
          target="_blank"
          rel="noopener"
          class="inline-block px-12 py-5 text-xs tracking-[0.28em] uppercase transition-all duration-300 hover:opacity-90"
          style="background: var(--color-accent); color: var(--color-bg)"
          data-hover
        >
          Book on Airbnb
        </a>
      ) : (
        <a
          href="/#contact"
          class="inline-block px-12 py-5 text-xs tracking-[0.28em] uppercase transition-all duration-300 hover:opacity-90"
          style="background: var(--color-accent); color: var(--color-bg)"
          data-hover
        >
          Enquire to Book
        </a>
      )}
      <p class="text-xs mt-6" style="color: var(--color-muted)">
        1-week minimum · Check-in 3 pm · Check-out 11 am · $300 refundable damage deposit
      </p>
    </div>

  </main>

  <!-- ── LIGHTBOX ──────────────────────────────────────────────────────────── -->
  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button id="lb-close" aria-label="Close photo viewer">✕</button>
    <button id="lb-prev" class="lb-nav" aria-label="Previous photo">‹</button>
    <img id="lb-img" src="" alt="" draggable="false" />
    <button id="lb-next" class="lb-nav" aria-label="Next photo">›</button>
    <div id="lb-counter"></div>
  </div>

  <!-- ── Data injection for client JS ─────────────────────────────────────── -->
  <script id="page-data" type="application/json" set:html={JSON.stringify({ bookedDates, rate, pets, photos, name })}></script>

  <script>
    // ── Load data ─────────────────────────────────────────────────────────────
    const _raw     = JSON.parse(document.getElementById('page-data')!.textContent!);
    const BOOKED: Set<string> = new Set(_raw.bookedDates);
    const RATE: number    = _raw.rate;
    const PETS_OK: boolean = !!_raw.pets;
    const PET_FEE  = 50;
    let   petCount = 0;

    // ── Photo gallery — static hero, lightbox for all photos ─────────────────
    const galleryEl = document.getElementById('gallery')!;

    // ── Lightbox ──────────────────────────────────────────────────────────────
    const lightbox  = document.getElementById('lightbox')!;
    const lbImg     = document.getElementById('lb-img') as HTMLImageElement;
    const lbCounter = document.getElementById('lb-counter')!;
    const allSrcs   = (_raw.photos as string[]);
    let lbCur = 0;

    function lbOpen(idx: number) {
      lbCur = (idx + allSrcs.length) % allSrcs.length;
      lbImg.src = allSrcs[lbCur];
      lbImg.alt = `Photo ${lbCur + 1}`;
      lbCounter.textContent = `${lbCur + 1}  /  ${allSrcs.length}`;
      lightbox.classList.add('lb-open');
      document.body.style.overflow = 'hidden';
    }
    function lbClose() {
      lightbox.classList.remove('lb-open');
      document.body.style.overflow = '';
    }
    function lbShow(n: number) {
      lbCur = (n + allSrcs.length) % allSrcs.length;
      // Animate image swap
      lbImg.style.animation = 'none';
      void lbImg.offsetHeight; // reflow
      lbImg.style.animation = '';
      lbImg.src = allSrcs[lbCur];
      lbCounter.textContent = `${lbCur + 1}  /  ${allSrcs.length}`;
    }

    // Open lightbox on gallery click or "View all" button
    galleryEl.addEventListener('click', () => lbOpen(0));
    document.getElementById('gallery-expand')!.addEventListener('click', () => lbOpen(0));

    document.getElementById('lb-close')!.addEventListener('click', lbClose);
    document.getElementById('lb-prev')!.addEventListener('click', () => lbShow(lbCur - 1));
    document.getElementById('lb-next')!.addEventListener('click', () => lbShow(lbCur + 1));

    // Close on backdrop click
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) lbClose(); });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('lb-open')) return;
      if (e.key === 'Escape')      lbClose();
      if (e.key === 'ArrowLeft')   lbShow(lbCur - 1);
      if (e.key === 'ArrowRight')  lbShow(lbCur + 1);
    });

    // Touch swipe in lightbox
    let lbTX = 0;
    lightbox.addEventListener('touchstart', e => { lbTX = e.touches[0].clientX; }, { passive: true });
    lightbox.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - lbTX;
      if (Math.abs(dx) > 40) lbShow(lbCur + (dx < 0 ? 1 : -1));
    }, { passive: true });

    // ── Date selection helpers ────────────────────────────────────────────────
    const MONTHS_SHORT = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

    function fmtDate(ds: string) {
      const [y, m, d] = ds.split('-');
      return `${MONTHS_SHORT[+m - 1]} ${+d}, ${y}`;
    }

    function nightsBetween(a: string, b: string): number {
      return Math.round(Math.abs(new Date(b+'T12:00:00').getTime() - new Date(a+'T12:00:00').getTime()) / 86400000);
    }

    // Inclusive range of date strings
    function dateRange(a: string, b: string): string[] {
      const s = a <= b ? a : b;
      const e = a <= b ? b : a;
      const out: string[] = [];
      const d = new Date(s + 'T12:00:00');
      const end = new Date(e + 'T12:00:00');
      while (d <= end) {
        out.push(d.toISOString().slice(0, 10));
        d.setDate(d.getDate() + 1);
      }
      return out;
    }

    // True if any date strictly between a and b (exclusive endpoints) is booked
    function hasBlockedInside(a: string, b: string): boolean {
      const range = dateRange(a, b);
      return range.slice(1, -1).some(ds => BOOKED.has(ds));
    }

    // ── Selection state ───────────────────────────────────────────────────────
    let selStart: string | null = null;
    let selEnd:   string | null = null;
    let dragging = false;

    function clearHighlights() {
      document.querySelectorAll('.cal-day.sel-start, .cal-day.sel-end, .cal-day.sel-range')
        .forEach(el => el.classList.remove('sel-start', 'sel-end', 'sel-range'));
    }

    function paintHighlights(start: string | null, end: string | null) {
      clearHighlights();
      if (!start) return;
      if (!end || start === end) {
        document.querySelector(`[data-date="${start}"]`)?.classList.add('sel-start', 'sel-end');
        return;
      }
      const s = start <= end ? start : end;
      const e = start <= end ? end : start;
      document.querySelector(`[data-date="${s}"]`)?.classList.add('sel-start');
      document.querySelector(`[data-date="${e}"]`)?.classList.add('sel-end');
      dateRange(s, e).slice(1, -1).forEach(ds =>
        document.querySelector(`[data-date="${ds}"]`)?.classList.add('sel-range')
      );
    }

    function updateCalc(start: string | null, end: string | null) {
      const clearBtn   = document.getElementById('calc-clear')!;
      const checkinEl  = document.getElementById('calc-checkin')! as HTMLElement;
      const checkoutEl = document.getElementById('calc-checkout')! as HTMLElement;
      const nightsEl   = document.getElementById('calc-nights')!;
      const totalEl    = document.getElementById('calc-total')!;
      const footnoteEl = document.getElementById('calc-footnote')!;
      // These are always in the DOM (just hidden on non-pet pages via display:none)
      const petFeeRow  = document.getElementById('pet-fee-row')!;
      const petFeeEl   = document.getElementById('calc-pet-fee')!;

      if (!start) {
        checkinEl.textContent     = 'Select a date below';
        checkinEl.style.fontStyle = 'italic';
        checkinEl.style.color     = 'var(--color-muted)';
        checkoutEl.textContent    = '—';
        checkoutEl.style.color    = 'var(--color-muted)';
        nightsEl.textContent      = '—';
        nightsEl.style.color      = 'var(--color-muted)';
        totalEl.textContent       = '—';
        totalEl.style.color       = 'var(--color-muted)';
        totalEl.style.fontSize    = '';
        clearBtn.classList.add('calc-hidden');
        footnoteEl.classList.add('calc-hidden');
        if (PETS_OK) petFeeRow.classList.add('calc-hidden');
        return;
      }

      const s = start <= (end ?? start) ? start : (end ?? start);
      const e = end ? (start <= end ? end : start) : null;

      checkinEl.textContent     = fmtDate(s);
      checkinEl.style.fontStyle = 'normal';
      checkinEl.style.color     = 'var(--color-text)';
      clearBtn.classList.remove('calc-hidden');

      if (e && s !== e) {
        checkoutEl.textContent = fmtDate(e);
        checkoutEl.style.color = 'var(--color-text)';
        const nights   = nightsBetween(s, e);
        const petTotal = petCount * PET_FEE;
        const grand    = nights * RATE + petTotal;

        nightsEl.textContent   = `${nights} night${nights !== 1 ? 's' : ''}`;
        nightsEl.style.color   = 'var(--color-text)';

        if (PETS_OK) {
          if (petCount > 0) {
            petFeeEl.textContent = `$${petTotal.toLocaleString()}`;
            petFeeRow.classList.remove('calc-hidden');
          } else {
            petFeeRow.classList.add('calc-hidden');
          }
        }

        totalEl.textContent    = `$${grand.toLocaleString()}`;
        totalEl.style.color    = 'var(--color-accent)';
        totalEl.style.fontSize = '20px';
        footnoteEl.classList.remove('calc-hidden');
      } else {
        checkoutEl.textContent = '— select check-out date';
        checkoutEl.style.color = 'var(--color-muted)';
        nightsEl.textContent   = '—';
        nightsEl.style.color   = 'var(--color-muted)';
        totalEl.textContent    = '—';
        totalEl.style.color    = 'var(--color-muted)';
        totalEl.style.fontSize = '';
        if (PETS_OK) petFeeRow.classList.add('calc-hidden');
        footnoteEl.classList.add('calc-hidden');
      }
    }

    function setSelection(start: string | null, end: string | null) {
      selStart = start;
      selEnd   = end;
      paintHighlights(start, end);
      updateCalc(start, end);
      updateEnquireBtn(start, end);
    }

    // ── Wire up calendar days — mouse (desktop + tablet trackpad/stylus) ──────
    const calDays = Array.from(document.querySelectorAll<HTMLElement>('.cal-day'));

    calDays.forEach(el => {
      const ds      = el.dataset.date!;
      const blocked = el.classList.contains('cal-booked') || el.classList.contains('cal-past');

      el.addEventListener('mousedown', ev => {
        // Ignore if this is a touch-synthesised mouse event
        if ((ev as MouseEvent & { sourceCapabilities?: { firesTouchEvents: boolean } }).sourceCapabilities?.firesTouchEvents) return;
        if (blocked) return;
        ev.preventDefault();
        dragging = true;

        if (!selStart) {
          setSelection(ds, null);
        } else if (selEnd) {
          setSelection(ds, null);
        } else {
          if (ds === selStart) { setSelection(null, null); }
          else if (hasBlockedInside(selStart, ds)) {
            setSelection(ds, null);
          } else {
            const s = selStart <= ds ? selStart : ds;
            const e = selStart <= ds ? ds : selStart;
            setSelection(s, e);
            dragging = false;
          }
        }
      });

      el.addEventListener('mouseenter', () => {
        if (!dragging || !selStart || selEnd) return;
        if (blocked) return;
        if (hasBlockedInside(selStart, ds)) return;
        paintHighlights(selStart, ds);
        updateCalc(selStart, ds);
      });
    });

    document.addEventListener('mouseup', ev => {
      if ((ev as MouseEvent & { sourceCapabilities?: { firesTouchEvents: boolean } }).sourceCapabilities?.firesTouchEvents) return;
      if (!dragging) return;
      dragging = false;
      if (selStart) {
        const endEl = document.querySelector<HTMLElement>('.cal-day.sel-end:not(.sel-start)');
        if (endEl?.dataset.date && endEl.dataset.date !== selStart) {
          selEnd = endEl.dataset.date;
          updateCalc(selStart, selEnd);
          updateEnquireBtn(selStart, selEnd);
        }
      }
    });

    // ── Touch calendar — two-tap selection (phones + tablets using touch) ─────
    // touchend fires preventDefault() to stop the browser synthesising mouse
    // events after a tap, so there is no double-firing with the mouse handlers.
    // touchstart is passive so normal page scrolling is never blocked.
    const calGrid = document.getElementById('cal-grid')!;

    function dayElAtPoint(x: number, y: number): HTMLElement | null {
      const el = document.elementFromPoint(x, y) as HTMLElement | null;
      return el?.classList.contains('cal-day') ? el : null;
    }

    // Track touchstart position so we can ignore scroll gestures
    let tStartX = 0, tStartY = 0;
    calGrid.addEventListener('touchstart', ev => {
      tStartX = ev.touches[0].clientX;
      tStartY = ev.touches[0].clientY;
    }, { passive: true });

    calGrid.addEventListener('touchend', ev => {
      const t  = ev.changedTouches[0];
      const dx = Math.abs(t.clientX - tStartX);
      const dy = Math.abs(t.clientY - tStartY);

      // Ignore if finger moved more than 10px — user was scrolling, not tapping
      if (dx > 10 || dy > 10) return;

      // Prevent the browser from synthesising mousedown / click after this touch
      ev.preventDefault();

      const day = dayElAtPoint(t.clientX, t.clientY);
      if (!day) return;
      const ds      = day.dataset.date!;
      const blocked = day.classList.contains('cal-booked') || day.classList.contains('cal-past');
      if (blocked) return;

      if (!selStart) {
        setSelection(ds, null);
      } else if (selEnd) {
        // Range already set — restart from this tap
        setSelection(ds, null);
      } else {
        if (ds === selStart) {
          setSelection(null, null);
        } else if (hasBlockedInside(selStart, ds)) {
          // Can't straddle a booked date — restart
          setSelection(ds, null);
        } else {
          const s = selStart <= ds ? selStart : ds;
          const e = selStart <= ds ? ds : selStart;
          setSelection(s, e);
        }
      }
    }, { passive: false }); // passive:false required for preventDefault()

    // Clear button
    document.getElementById('calc-clear')!.addEventListener('click', () => setSelection(null, null));

    // ── Pet counter (only active on pet-friendly properties) ─────────────────
    if (PETS_OK) {
      const decBtn  = document.getElementById('pet-dec') as HTMLButtonElement;
      const incBtn  = document.getElementById('pet-inc') as HTMLButtonElement;
      const countEl = document.getElementById('pet-count')!;

      function syncPetUI() {
        countEl.textContent = String(petCount);
        decBtn.disabled = petCount === 0;
        incBtn.disabled = petCount === 3;
        updateCalc(selStart, selEnd);
      }

      decBtn.addEventListener('click', () => { if (petCount > 0) { petCount--; syncPetUI(); } });
      incBtn.addEventListener('click', () => { if (petCount < 3) { petCount++; syncPetUI(); } });
    }

    // ── Today highlight ───────────────────────────────────────────────────────
    const now = new Date();
    const todayDs = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
    document.querySelector(`[data-date="${todayDs}"]`)?.classList.add('cal-today');

    // ── Booking enquiry flow ──────────────────────────────────────────────────
    const COTTAGE_NAME: string = _raw.name;

    const enquireBtnWrap  = document.getElementById('enquire-btn-wrap')!;
    const enquireBtn      = document.getElementById('enquire-btn')!;
    const enquirySection  = document.getElementById('enquiry-section')!;
    const enqForm         = document.getElementById('enq-form') as HTMLFormElement;
    const enqMessageEl    = document.getElementById('enq-message') as HTMLTextAreaElement;
    const enqSuccess      = document.getElementById('enq-success')!;
    const enqSuccessMsg   = document.getElementById('enq-success-msg')!;
    const enqError        = document.getElementById('enq-error')!;
    const enqErrorMsg     = document.getElementById('enq-error-msg')!;
    const enqSubmit       = document.getElementById('enq-submit') as HTMLButtonElement;

    function buildEnquiryMessage(start: string, end: string): string {
      const nights   = nightsBetween(start, end);
      const petTotal = petCount * PET_FEE;
      const grand    = nights * RATE + petTotal;
      let msg = `Hi,\n\nI'd like to enquire about booking ${COTTAGE_NAME} from ${fmtDate(start)} to ${fmtDate(end)} (${nights} night${nights !== 1 ? 's' : ''}).\n\nEstimated total: $${grand.toLocaleString()} + taxes.`;
      if (petCount > 0) {
        msg += `\n\nWe'll be bringing ${petCount} pet${petCount > 1 ? 's' : ''} ($${petTotal} pet fee included).`;
      }
      msg += '\n\nPlease let me know if these dates are available and how to proceed with the booking.\n\nThank you!';
      return msg;
    }

    function updateEnquireBtn(start: string | null, end: string | null) {
      const hasRange = !!(start && end && start !== end);
      // Fade button in/out — space always reserved so calc panel never shifts
      enquireBtn.classList.toggle('enq-visible', hasRange);

      if (!hasRange) {
        // Collapse the form if dates are cleared
        enquirySection.style.maxHeight = '0';
      } else if (enquirySection.style.maxHeight && enquirySection.style.maxHeight !== '0px') {
        // Form already open — refresh the pre-filled message live
        enqMessageEl.value = buildEnquiryMessage(start!, end!);
      }
    }

    enquireBtn.addEventListener('click', () => {
      if (!selStart || !selEnd) return;
      // Reset form to clean state each time it's opened fresh
      enqSuccess.style.display = 'none';
      enqError.style.display   = 'none';
      enqForm.style.display    = '';
      enqSubmit.disabled       = false;
      enqSubmit.textContent    = 'Send Enquiry';
      // Pre-fill message
      enqMessageEl.value = buildEnquiryMessage(selStart, selEnd);
      // Reveal section
      enquirySection.style.maxHeight = '1400px';
      // Wait for the max-height expand transition (0.3s in CSS) to finish so the
      // final height is known before we scroll — otherwise scrollIntoView measures
      // the form's mid-animation height and lands at the wrong position.
      setTimeout(() => {
        // block: 'center' visually centers the form in the viewport, so it's
        // comfortably framed rather than slammed against the bottom edge.
        enquirySection.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 320);
    });

    enqForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd   = new FormData(enqForm);
      const data = {
        firstName: (fd.get('firstName') as string)?.trim() ?? '',
        lastName:  (fd.get('lastName')  as string)?.trim() ?? '',
        email:     (fd.get('email')     as string)?.trim() ?? '',
        cabin:     COTTAGE_NAME,
        message:   (fd.get('message')   as string)?.trim() ?? '',
      };

      enqError.style.display = 'none';

      if (!data.firstName || !data.email || !data.message) {
        enqErrorMsg.textContent = 'Please fill in all required fields.';
        enqError.style.display  = 'block';
        return;
      }

      enqSubmit.disabled     = true;
      enqSubmit.textContent  = 'Sending…';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        let json: Record<string, unknown> = {};
        try { json = await res.json(); } catch { /* non-JSON body */ }

        if (!res.ok || json.error) {
          enqErrorMsg.textContent = (json.error as string) || 'Something went wrong — please try again.';
          enqError.style.display  = 'block';
          enqSubmit.disabled      = false;
          enqSubmit.textContent   = 'Send Enquiry';
        } else {
          enqForm.style.display   = 'none';
          enqSuccessMsg.textContent = `We'll confirm ${COTTAGE_NAME} for ${fmtDate(selStart!)} – ${fmtDate(selEnd!)} shortly. Check your inbox for our reply.`;
          enqSuccess.style.display  = 'block';
        }
      } catch {
        enqErrorMsg.textContent = 'Network error — please check your connection and try again.';
        enqError.style.display  = 'block';
        enqSubmit.disabled      = false;
        enqSubmit.textContent   = 'Send Enquiry';
      }
    });
  </script>

</Layout>
