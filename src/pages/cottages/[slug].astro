      alt={`${name} — banner`}
      loading="eager"
      draggable="false"
    />
    <button id="gallery-expand" aria-label={`View all ${photoCount} photos`}>
      <svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M1 5V1h4M9 1h4v4M13 9v4H9M5 13H1V9"/>
      </svg>
      View all {photoCount} photos
    </button>
  </div>

  <!-- ── MAIN CONTENT ───────────────────────────────────────────────────────── -->
  <main class="max-w-5xl mx-auto px-6 py-14 md:py-24">

    <!-- Header -->
    <div class="mb-14 md:mb-18">
      <p class="text-xs tracking-[0.3em] uppercase mb-3" style="color: var(--color-accent)">
        {isTreehouse ? 'Something Different · Griffith, Ontario' : `${number} Harrison Trail · Griffith, Ontario`}
      </p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-light mb-3" style="font-family: 'Cormorant', serif">{name}</h1>
      <p class="text-xs tracking-[0.22em] uppercase mb-8" style="color: var(--color-accent)">{tagline}</p>
      <div class="divider mb-8"></div>
      <div class="flex flex-wrap gap-x-10 gap-y-3 text-sm mb-8" style="color: var(--color-muted)">
        <span><span style="color:var(--color-accent)">Sleeps&ensp;</span>{sleeps}</span>
        <span><span style="color:var(--color-accent)">Beds&ensp;</span>{bedDetail}</span>
        <span><span style="color:var(--color-accent)">Pets&ensp;</span>{pets ? 'Welcome' : 'Not accepted'}</span>
        <span><span style="color:var(--color-accent)">Access&ensp;</span>{isTreehouse ? '650 m forest trail' : 'Direct road access'}</span>
      </div>
      <p class="text-base leading-loose max-w-2xl" style="color: var(--color-muted)">{longDescription}</p>
    </div>

    <!-- Features -->
    <div class="mb-16">
      <p class="text-xs tracking-[0.25em] uppercase mb-6" style="color: var(--color-accent)">What's included</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-y-3 gap-x-8">
        {features.map(f => (
          <div class="flex items-start gap-3">
            <div class="feature-dot"></div>
            <span class="text-sm leading-relaxed" style="color: var(--color-muted)">{f}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ── AVAILABILITY + PRICE CALCULATOR ─────────────────────────────────── -->
    <div class="mb-20">
      <div class="divider mb-10"></div>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-8">
        <div>
          <p class="text-xs tracking-[0.3em] uppercase mb-2" style="color: var(--color-accent)">Availability</p>
