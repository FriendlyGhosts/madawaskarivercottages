// ─── Component props ──────────────────────────────────────────────────────────
interface Props {
  slug: string;
  number: string | null;
  name: string;
  tagline: string;
  sleeps: number;
  bedDetail: string;
  pets: boolean;
  photoFolder: string;
  photoCount: number;
  heroPhoto: number;
  airbnbId: string | null;
  rate: number;
  description: string;
  longDescription: string;
  isTreehouse: boolean;
  features: string[];
  bookedDates: string[];
}

const {
  name, tagline, sleeps, bedDetail, pets,
  photoFolder, photoCount, heroPhoto, airbnbId, rate,
  longDescription, isTreehouse, features, bookedDates,
} = Astro.props;

const number = Astro.props.number;
const photos    = Array.from({ length: photoCount }, (_, i) => `/images/cottages/${photoFolder}-${i + 1}.jpg`);
const bannerSrc = `/images/cottages/${photoFolder}-${heroPhoto}.jpg`;
const calMonths = buildSummerCalendar(bookedDates);
const calYear = calMonths[0].year;
---

<Layout title={`${name} · Madawaska River Cottages`} description={Astro.props.description}>

  <style>
    /* ── Nav — parchment bar, slides in on load ─────────── */
    nav {
      background: rgba(242, 236, 224, 0.93) !important;
      backdrop-filter: blur(12px) !important;
      -webkit-backdrop-filter: blur(12px) !important;
      border-bottom: 1px solid rgba(184, 168, 122, 0.35);
      transition: transform 0.35s ease, background 0.3s ease;
      animation: navSlideIn 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    html.night nav {
      background: rgba(12, 18, 16, 0.93) !important;
      border-bottom-color: rgba(30, 48, 40, 0.7);
    }
    @keyframes navSlideIn {
      from { transform: translateY(-110%); }
      to   { transform: translateY(0); }
    }
    nav.nav-hidden { transform: translateY(-110%) !important; }

    /* ── Gallery ─────────────────────────────────────────── */
    #gallery {
      position: relative; width: 100%;
      height: 62vh; min-height: 320px; max-height: 680px;
      background: var(--color-surface); overflow: hidden;
      cursor: zoom-in;
    }
    #gallery-hero {
      width: 100%; height: 100%; object-fit: cover;
      display: block;
    }

    /* "View all photos" button */
    #gallery-expand {
      position: absolute; bottom: 16px; right: 16px; z-index: 3;
      background: rgba(0,0,0,0.46); backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,0.28); border-radius: 5px;
      color: rgba(255,255,255,0.92); font-size: 12px;
      letter-spacing: 0.06em; padding: 7px 12px;
      display: flex; align-items: center; gap: 6px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
    }
    #gallery-expand:hover { background: rgba(0,0,0,0.68); border-color: rgba(255,255,255,0.55); }

    /* ── Lightbox ────────────────────────────────────────── */
    #lightbox {
      display: none;
      position: fixed; inset: 0; z-index: 10000;
      background: rgba(0,0,0,0.96);
      align-items: center; justify-content: center;
    }
    #lightbox.lb-open {
      display: flex;
      animation: lbFadeIn 0.2s ease;
    }
    @keyframes lbFadeIn { from { opacity:0 } to { opacity:1 } }
    #lb-img {
      max-width: 95vw; max-height: 90vh;
      object-fit: contain; display: block;
      user-select: none; -webkit-user-select: none;
      animation: lbImgIn 0.18s ease;
    }
    @keyframes lbImgIn { from { opacity:0; transform:scale(0.97) } to { opacity:1; transform:scale(1) } }
    #lb-close {
      position: absolute; top: 16px; right: 20px;
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18);
      border-radius: 50%; width: 40px; height: 40px;
      color: rgba(255,255,255,0.8); font-size: 18px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: background 0.2s, color 0.2s;
    }
    #lb-close:hover { background: rgba(255,255,255,0.18); color: #fff; }
    .lb-nav {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.18);
      color: rgba(255,255,255,0.8); font-size: 30px; line-height: 1;
      width: 50px; height: 50px; border-radius: 50%; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s, color 0.2s;
    }
    .lb-nav:hover { background: rgba(255,255,255,0.18); color: #fff; }
    #lb-prev { left: 16px; }
    #lb-next { right: 16px; }
    @media (max-width: 600px) { .lb-nav { width: 38px; height: 38px; font-size: 22px; } }
    #lb-counter {
      position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
      color: rgba(255,255,255,0.45); font-size: 11px; letter-spacing: 0.18em;
      text-transform: uppercase; pointer-events: none;
    }

    /* ── Calendar grid ───────────────────────────────────── */
    .cal-grid-full { display: grid; grid-template-columns: repeat(2, 1fr); gap: 36px 56px; }
    @media (max-width: 767px) { .cal-grid-full { grid-template-columns: 1fr; } }
    .cal-month-name { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 10px; }
    .cal-days-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 3px; }
    .cal-dow { font-size: 10px; letter-spacing: 0.06em; text-align: center; padding: 4px 0 8px; color: var(--color-muted); text-transform: uppercase; }
    .cal-day {
      aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
      font-size: 13px; border-radius: 50%; cursor: pointer;
      color: var(--color-text); transition: background 0.12s, color 0.12s;
      user-select: none; -webkit-user-select: none;
    }
    @media (hover: hover) {
      .cal-day:not(.cal-booked):not(.cal-past):hover { background: var(--color-hover); }
    }

    /* Booked: clearly unavailable — diagonal strike, distinct color */
    .cal-booked {
      cursor: not-allowed;
      color: var(--color-muted);
      opacity: 0.75;
      text-decoration: line-through;
      text-decoration-color: var(--color-muted);
      text-decoration-thickness: 1.5px;
      background: rgba(120, 90, 50, 0.08);
      border-radius: 50%;
    }
    html.night .cal-booked { background: rgba(255,255,255,0.05); }

    /* past overrides booked — uniform fade for all historical dates */
    .cal-past {
      color: var(--color-muted) !important;
      opacity: 0.25 !important;
      cursor: default !important;
      background: none !important;
      text-decoration: none !important;
      border-radius: 50% !important;
    }
    .cal-today  { font-weight: 500; outline: 1px solid var(--color-accent); outline-offset: -2px; }

    /* Selection */
    .cal-day.sel-start,
    .cal-day.sel-end {
      background: var(--color-accent) !important;
      color: var(--color-bg) !important;
      border-radius: 50% !important;
    }
    .cal-day.sel-range {
      background: rgba(46,107,138,0.16);
      border-radius: 0;
      color: var(--color-text);
    }
    html.night .cal-day.sel-range { background: rgba(82,184,160,0.16); }
    .cal-day.sel-start:not(.sel-end) { border-radius: 50% 0 0 50% !important; }
    .cal-day.sel-end:not(.sel-start)  { border-radius: 0 50% 50% 0 !important; }

    /* Legend */
    .cal-legend { display: flex; gap: 18px; flex-wrap: wrap; }
    .cal-legend-item { display: flex; align-items: center; gap: 6px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-muted); }
    .cal-legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    /* ── Calculator ──────────────────────────────────────── */
    #calc-panel {
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      padding: 24px 28px 20px;
      margin-bottom: 40px;
    }
    .calc-row {
      display: flex; justify-content: space-between; align-items: baseline;
      padding: 7px 0; border-bottom: 1px solid var(--color-border);
    }
    .calc-row:last-child { border-bottom: none; }
    .calc-label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-muted); }
    .calc-value { font-size: 13px; color: var(--color-text); }
    #calc-total-row .calc-value { font-size: 20px; font-family: 'Cormorant', serif; color: var(--color-accent); }
    /* Use visibility (not display) so the panel never changes height */
    .calc-hidden { visibility: hidden; }

    /* ── Pet counter ─────────────────────────────────────── */
    .pet-btn {
      width: 28px; height: 28px; border-radius: 50%;
      border: 1px solid var(--color-border);
      background: none; cursor: pointer;
      font-size: 18px; line-height: 1;
      color: var(--color-text);
      display: flex; align-items: center; justify-content: center;
      transition: border-color 0.2s, color 0.2s;
      flex-shrink: 0;
    }
    .pet-btn:hover:not([disabled]) { border-color: var(--color-accent); color: var(--color-accent); }
    .pet-btn[disabled] { opacity: 0.25; cursor: not-allowed; }

    /* ── Misc ────────────────────────────────────────────── */
    .divider { width: 48px; height: 1px; background: var(--color-accent); }
    .feature-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; margin-top: 7px; }

    /* ── Enquiry button & form ───────────────────────────── */
    #enquire-btn-wrap {
      margin-top: 16px;
    }
    #enquire-btn {
      width: 100%;
      padding: 14px 20px;
      background: var(--color-accent); color: var(--color-bg);
      font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
      border: none; cursor: pointer;
      display: block;
      /* Hidden by default — opacity keeps space reserved so calc panel never grows */
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.35s ease;
    }
    #enquire-btn.enq-visible {
      opacity: 1;
      pointer-events: auto;
    }
    #enquire-btn:hover { opacity: 0.85; }
    #enquiry-section {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    #enq-form input, #enq-form textarea {
      width: 100%;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      color: var(--color-text);
      font-size: 13px;
      padding: 10px 12px;
      outline: none;
      transition: border-color 0.2s;
      font-family: 'Inter', sans-serif;
    }
    #enq-form input:focus, #enq-form textarea:focus {
      border-color: var(--color-accent);
    }
    #enq-label {
      font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--color-muted); display: block; margin-bottom: 6px;
    }
    #enq-submit {
      width: 100%; padding: 16px 20px;
      background: var(--color-accent); color: var(--color-bg);
      font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
      border: none; cursor: pointer; transition: opacity 0.2s; display: block;
    }
    #enq-submit:hover { opacity: 0.85; }
    #enq-submit:disabled { opacity: 0.5; cursor: not-allowed; }
  </style>

