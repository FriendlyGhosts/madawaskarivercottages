---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Madawaska River Cottages',
  description = 'Four private riverside cottages on the Madawaska River. Escape the ordinary.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>if(localStorage.getItem('night-mode')==='true')document.documentElement.classList.add('night');</script>
  </head>
  <body>
    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>
    <canvas id="wave-canvas" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none;"></canvas>

    <slot />

    <script>
      // Custom cursor
      const dot = document.getElementById('cursor-dot')!;
      const ring = document.getElementById('cursor-ring')!;

      let ringX = 0, ringY = 0;
      let mouseX = 0, mouseY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        dot.style.left = mouseX + 'px';
        dot.style.top = mouseY + 'px';
      });

      function animateRing() {
        ringX += (mouseX - ringX) * 0.12;
        ringY += (mouseY - ringY) * 0.12;
        ring.style.left = ringX + 'px';
        ring.style.top = ringY + 'px';
        requestAnimationFrame(animateRing);
      }
      animateRing();

      // Hover effect on interactive elements
      const hoverTargets = document.querySelectorAll('a, button, [data-hover]');
      hoverTargets.forEach(el => {
        el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
        el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
      });

      // Scroll reveal
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.12 });

      reveals.forEach(el => observer.observe(el));

      // Gerstner sum-of-cosines waves + per-layer bowstring surface tension
      const waveCanvas = document.getElementById('wave-canvas') as HTMLCanvasElement;
      const wctx = waveCanvas.getContext('2d')!;
      let wW = 0, wH = 0;

      function wResize() {
        wW = waveCanvas.width = window.innerWidth;
        wH = waveCanvas.height = window.innerHeight;
      }
      window.addEventListener('resize', wResize);
      wResize();

      let wT = 0;

      type WComp = [number, number, number, number]; // [A, k, ω, φ]
      function wc(A: number, lambda: number, speed: number, phi: number): WComp {
        const k = (2 * Math.PI) / lambda;
        return [A, k, k * speed, phi];
      }

      interface GLayer { baseRatio: number; comps: WComp[]; dayColor: string; nightColor: string; }
      const gLayers: GLayer[] = [
        { baseRatio: 0.50, dayColor: 'rgba(28,80,110,0.06)',  nightColor: 'rgba(22,55,30,0.08)',
          comps: [wc(10,760,1.8,0.00), wc(4.5,440,1.4,1.10), wc(2.0,230,1.0,2.30), wc(0.8,115,0.7,0.55)] },
        { baseRatio: 0.60, dayColor: 'rgba(28,80,110,0.09)',  nightColor: 'rgba(22,55,30,0.11)',
          comps: [wc(9,690,1.9,0.80), wc(4.0,400,1.5,2.00), wc(1.8,210,1.1,0.90), wc(0.9,105,0.8,1.70)] },
        { baseRatio: 0.69, dayColor: 'rgba(28,80,110,0.12)',  nightColor: 'rgba(22,55,30,0.14)',
          comps: [wc(8,720,1.7,1.60), wc(3.5,420,1.3,0.40), wc(2.2,240,0.9,2.80), wc(1.0,120,0.6,1.20)] },
        { baseRatio: 0.77, dayColor: 'rgba(28,80,110,0.15)',  nightColor: 'rgba(22,55,30,0.17)',
          comps: [wc(7,680,2.0,2.40), wc(3.0,380,1.6,0.70), wc(1.6,200,1.2,1.80), wc(0.7,100,0.9,3.10)] },
        { baseRatio: 0.84, dayColor: 'rgba(28,80,110,0.19)',  nightColor: 'rgba(22,55,30,0.21)',
          comps: [wc(6,640,2.1,3.20), wc(2.5,360,1.7,1.50), wc(1.4,190,1.3,0.30), wc(0.6,95,1.0,2.10)] },
      ];

      // Per-layer bowstring state — snap springs back as damped oscillation, no point-source ripple
      interface BowState {
        engaged: boolean; releasing: boolean;
        pullX: number; pullAmt: number;
        releaseAmt: number; releaseT: number;
        cooldown: number;
      }
      const bowStates: BowState[] = gLayers.map(() => ({
        engaged: false, releasing: false,
        pullX: 0, pullAmt: 0,
        releaseAmt: 0, releaseT: 0,
        cooldown: 0,
      }));
      const ENGAGE_DIST = 11;  // px from surface to latch
      const SNAP_DIST   = 62;  // px of pull before snap
      const BOW_HW      = 140; // half-width of bowstring tent (px)
      const COOLDOWN    = 0;   // no cooldown — every crossing triggers a ripple

      const PULSE_SPEED = 2.2;  // px per frame — visible travel without feeling like a shockwave
      const PULSE_DECAY = 0.018; // slow fade — pulses travel a good distance before dying
      const PULSE_HW0   = 80;   // initial half-width of each outgoing pulse (tighter than the pull)

      function compY(gl: GLayer, x: number, t: number): number {
        let y = 0;
        for (const [A, k, w, phi] of gl.comps) y += A * Math.cos(k * x + w * t + phi);
        return y;
      }

      // Tent shape: straight lines from base to a sharp peak — real bowstring geometry
      function tent(dx: number, hw: number): number {
        const t = 1 - Math.abs(dx) / hw;
        return t > 0 ? t : 0;
      }

      function bowDeform(st: BowState, x: number, t: number): number {
        if (!st.engaged && !st.releasing) return 0;

        if (st.engaged) {
          // Tent-shaped pull: sharp peak at cursor, straight lines to either side
          if (Math.abs(st.pullAmt) < 0.3) return 0;
          const dx = x - st.pullX;
          if (Math.abs(dx) >= BOW_HW) return 0;
          return st.pullAmt * tent(dx, BOW_HW);
        }

        // Releasing: two tent pulses travel outward, each with good amplitude
        const age = t - st.releaseT;
        const amp = st.releaseAmt * Math.exp(-age * PULSE_DECAY);
        if (Math.abs(amp) < 0.3) return 0;

        // Pulse widens as it disperses (water dispersion)
        const hw = PULSE_HW0 + age * 1.4;
        let result = 0;
        for (const cx of [st.pullX - PULSE_SPEED * age, st.pullX + PULSE_SPEED * age]) {
          const dx = x - cx;
          if (Math.abs(dx) < hw) {
            result += amp * 0.55 * tent(dx, hw);
          }
        }
        return result;
      }

      function waveY(gl: GLayer, li: number, x: number, t: number): number {
        return compY(gl, x, t) + bowDeform(bowStates[li], x, t);
      }

      const NW = 180;
      function drawGLayer(gl: GLayer, li: number) {
        const isNight = document.documentElement.classList.contains('night');
        const bY   = gl.baseRatio * wH;
        const step = wW / (NW - 1);
        wctx.beginPath();
        let prevY = bY + waveY(gl, li, 0, wT);
        wctx.moveTo(0, prevY);
        for (let i = 1; i < NW; i++) {
          const x0 = (i - 1) * step, x1 = i * step;
          const y1 = bY + waveY(gl, li, x1, wT);
          wctx.quadraticCurveTo(x0, prevY, (x0 + x1) / 2, (prevY + y1) / 2);
          prevY = y1;
        }
        wctx.lineTo(wW, wH);
        wctx.lineTo(0, wH);
        wctx.closePath();
        wctx.fillStyle = isNight ? gl.nightColor : gl.dayColor;
        wctx.fill();
      }

      // Shared wave interaction — used by both mouse and touch
      function handleWaveInteraction(mx: number, my: number) {
        bowStates.forEach(st => { if (st.cooldown > 0) st.cooldown--; });
        gLayers.forEach((gl, i) => {
          const st = bowStates[i];
          const surf = gl.baseRatio * wH + compY(gl, mx, wT);
          if (st.engaged) {
            st.pullX   = mx;
            st.pullAmt = my - surf;
            if (Math.abs(st.pullAmt) >= SNAP_DIST) {
              st.releasing  = true;
              st.releaseAmt = st.pullAmt;
              st.releaseT   = wT;
              st.engaged    = false;
            }
          } else if (Math.abs(my - surf) <= ENGAGE_DIST) {
            st.engaged = true; st.releasing = false; st.pullX = mx; st.pullAmt = 0;
          }
        });
      }

      // Mouse
      let lastMX = -1;
      document.addEventListener('mousemove', (e) => {
        if (lastMX < 0) { lastMX = e.clientX; return; }
        handleWaveInteraction(e.clientX, e.clientY);
        lastMX = e.clientX;
      });

      // Touch — treat each finger move as a wave interaction
      document.addEventListener('touchstart', (e) => {
        e.preventDefault();
        const t = e.touches[0];
        handleWaveInteraction(t.clientX, t.clientY);
      }, { passive: false });

      document.addEventListener('touchmove', (e) => {
        e.preventDefault();
        const t = e.touches[0];
        handleWaveInteraction(t.clientX, t.clientY);
      }, { passive: false });

      function animateWaves() {
        // Check if traveling pulses have faded out
        bowStates.forEach(st => {
          if (st.releasing) {
            const age = wT - st.releaseT;
            const amp = st.releaseAmt * Math.exp(-age * PULSE_DECAY);
            if (Math.abs(amp) < 0.3) {
              st.releasing = false; st.pullAmt = 0; st.cooldown = COOLDOWN;
            }
          }
        });
        wctx.clearRect(0, 0, wW, wH);
        wT += 1;
        gLayers.forEach((l, li) => drawGLayer(l, li));
        requestAnimationFrame(animateWaves);
      }
      animateWaves();

      // Hide nav on scroll down, reveal on scroll up
      const navEl = document.querySelector('nav') as HTMLElement;
      let lastScrollY = 0;
      window.addEventListener('scroll', () => {
        const y = window.scrollY;
        if (y > lastScrollY && y > 80) {
          navEl?.classList.add('nav-hidden');
        } else {
          navEl?.classList.remove('nav-hidden');
        }
        lastScrollY = y;
      }, { passive: true });

      // Night mode toggle
      const modeToggle = document.getElementById('mode-toggle');
      function updateToggleIcon() {
        if (modeToggle) modeToggle.textContent = document.documentElement.classList.contains('night') ? '○' : '☽';
      }
      updateToggleIcon();
      modeToggle?.addEventListener('click', () => {
        const isNight = document.documentElement.classList.toggle('night');
        localStorage.setItem('night-mode', String(isNight));
        updateToggleIcon();
      });
    </script>
  </body>
</html>
