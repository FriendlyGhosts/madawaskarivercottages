---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Madawaska River Cottages',
  description = 'Four private riverside cottages on the Madawaska River. Escape the ordinary.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Josefin+Slab:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel+Decorative:wght@400;700&family=Uncial+Antiqua&family=Pirata+One&family=Fondamento:ital@0;1&family=Metamorphous&family=Caesar+Dressing&family=Mystery+Quest&family=Cormorant:ital,wght@0,300;0,400;1,300&family=Cormorant+Unicase:wght@300;400;500&family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;1,6..96,400&family=Poiret+One&family=Inter:wght@300;400;500&display=swap" />
    <script is:inline>if(localStorage.getItem('night-mode')==='true')document.documentElement.classList.add('night');</script>
  </head>
  <body>
    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>
    <canvas id="wave-canvas" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none;"></canvas>

    <slot />

    <script>
      // Custom cursor
      const dot = document.getElementById('cursor-dot')!;
      const ring = document.getElementById('cursor-ring')!;

      let ringX = 0, ringY = 0;
      let mouseX = 0, mouseY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        dot.style.left = mouseX + 'px';
        dot.style.top = mouseY + 'px';
      });

      function animateRing() {
        ringX += (mouseX - ringX) * 0.12;
        ringY += (mouseY - ringY) * 0.12;
        ring.style.left = ringX + 'px';
        ring.style.top = ringY + 'px';
        requestAnimationFrame(animateRing);
      }
      animateRing();

      // Hover effect on interactive elements
      const hoverTargets = document.querySelectorAll('a, button, [data-hover]');
      hoverTargets.forEach(el => {
        el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
        el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
      });

      // Scroll reveal
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.12 });

      reveals.forEach(el => observer.observe(el));

      // Gerstner sum-of-cosines waves + per-layer bowstring surface tension
      const waveCanvas = document.getElementById('wave-canvas') as HTMLCanvasElement;
      const wctx = waveCanvas.getContext('2d')!;
      let wW = 0, wH = 0;

      function wResize() {
        const dpr = window.devicePixelRatio || 1;
        wW = window.innerWidth;
        wH = window.innerHeight;
        waveCanvas.width  = Math.round(wW * dpr);
        waveCanvas.height = Math.round(wH * dpr);
        wctx.setTransform(dpr, 0, 0, dpr, 0, 0); // scale once, resets on each call
      }
      window.addEventListener('resize', wResize);
      wResize();

      let wT = 0;
      const wStartTime = performance.now();

      type WComp = [number, number, number, number]; // [A, k, ω, φ]
      function wc(A: number, lambda: number, speed: number, phi: number): WComp {
        const k = (2 * Math.PI) / lambda;
        return [A, k, k * speed, phi];
      }

      // Master switch for the sky-aurora bands — flip to true to re-enable them
      // during zen mode without touching anything else.
      const SKY_WAVES_ENABLED = false;

      // GLayer.fillUp: polygon fills toward y=0 (sky) instead of y=wH (water).
      // GLayer.zenOnly: layer is hidden + non-interactive unless `zen-mode` class is on <html>.
      interface GLayer {
        baseRatio: number;
        comps: WComp[];
        dayColor: string;
        nightColor: string;
        fillUp?: boolean;
        zenOnly?: boolean;
      }
      const gLayers: GLayer[] = [
        // ── River waves — bottom half of viewport, always visible ──────────────
        { baseRatio: 0.50, dayColor: 'rgba(28,80,110,0.06)',  nightColor: 'rgba(15,55,45,0.14)',
          comps: [wc(10,760,1.8,0.00), wc(4.5,440,1.4,1.10), wc(2.0,230,1.0,2.30), wc(0.8,115,0.7,0.55)] },
        { baseRatio: 0.60, dayColor: 'rgba(28,80,110,0.09)',  nightColor: 'rgba(15,55,45,0.20)',
          comps: [wc(9,690,1.9,0.80), wc(4.0,400,1.5,2.00), wc(1.8,210,1.1,0.90), wc(0.9,105,0.8,1.70)] },
        { baseRatio: 0.69, dayColor: 'rgba(28,80,110,0.12)',  nightColor: 'rgba(15,55,45,0.26)',
          comps: [wc(8,720,1.7,1.60), wc(3.5,420,1.3,0.40), wc(2.2,240,0.9,2.80), wc(1.0,120,0.6,1.20)] },
        { baseRatio: 0.77, dayColor: 'rgba(28,80,110,0.15)',  nightColor: 'rgba(15,55,45,0.33)',
          comps: [wc(7,680,2.0,2.40), wc(3.0,380,1.6,0.70), wc(1.6,200,1.2,1.80), wc(0.7,100,0.9,3.10)] },
        { baseRatio: 0.84, dayColor: 'rgba(28,80,110,0.19)',  nightColor: 'rgba(15,55,45,0.40)',
          comps: [wc(6,640,2.1,3.20), wc(2.5,360,1.7,1.50), wc(1.4,190,1.3,0.30), wc(0.6,95,1.0,2.10)] },

        // ── Sky waves (aurora) — top of viewport, zen-mode only ───────────────
        // Same wave physics as the rivers, just inverted vertically and recoloured.
        // Layers cascade outward from the topmost band so each colour peeks through.
        { baseRatio: 0.42, fillUp: true, zenOnly: true,
          dayColor: 'rgba(120,140,235,0.10)', nightColor: 'rgba(120,140,235,0.22)',
          comps: [wc(6,640,2.1,3.20), wc(2.5,360,1.7,1.50), wc(1.4,190,1.3,0.30), wc(0.6,95,1.0,2.10)] },
        { baseRatio: 0.34, fillUp: true, zenOnly: true,
          dayColor: 'rgba(225,100,185,0.10)', nightColor: 'rgba(225,100,185,0.22)',
          comps: [wc(7,680,2.0,2.40), wc(3.0,380,1.6,0.70), wc(1.6,200,1.2,1.80), wc(0.7,100,0.9,3.10)] },
        { baseRatio: 0.27, fillUp: true, zenOnly: true,
          dayColor: 'rgba(90,205,220,0.12)',  nightColor: 'rgba(90,205,220,0.26)',
          comps: [wc(8,720,1.7,1.60), wc(3.5,420,1.3,0.40), wc(2.2,240,0.9,2.80), wc(1.0,120,0.6,1.20)] },
        { baseRatio: 0.20, fillUp: true, zenOnly: true,
          dayColor: 'rgba(170,110,240,0.13)', nightColor: 'rgba(170,110,240,0.28)',
          comps: [wc(9,690,1.9,0.80), wc(4.0,400,1.5,2.00), wc(1.8,210,1.1,0.90), wc(0.9,105,0.8,1.70)] },
        { baseRatio: 0.13, fillUp: true, zenOnly: true,
          dayColor: 'rgba(110,225,155,0.14)', nightColor: 'rgba(110,225,155,0.30)',
          comps: [wc(10,760,1.8,0.00), wc(4.5,440,1.4,1.10), wc(2.0,230,1.0,2.30), wc(0.8,115,0.7,0.55)] },
      ];

      // Per-layer bowstring state — supports multiple concurrent pulses
      interface Pulse { pullX: number; releaseAmt: number; releaseT: number; hw0?: number; riseT?: number; decay?: number; speed?: number; }
      interface BowState { engaged: boolean; pullX: number; pullAmt: number; pulses: Pulse[]; cooldownUntil: number; }
      const bowStates: BowState[] = gLayers.map(() => ({
        engaged: false, pullX: 0, pullAmt: 0, pulses: [], cooldownUntil: 0,
      }));
      const isTouchDevice = navigator.maxTouchPoints > 0;
      // Mobile: a finger is ~40-60px wide and bands are spaced ~50-80px apart on small screens.
      // ENGAGE_DIST must cover ~half the band spacing so any touch lands within *some* band's
      // zone — otherwise single-band engagement leaves big dead zones between bands.
      const ENGAGE_DIST = isTouchDevice ? 50 : 11;
      const SNAP_DIST   = isTouchDevice ? 55 : 52;  // how far you can pull a band before it snaps
      const BOW_HW      = 60;                        // narrower engaged deformation (was 85)

      const PULSE_SPEED      = 2.2;
      const PULSE_DECAY      = 0.0018;               // tidal-wave/explosion default
      const PULSE_HW0        = 110;
      const USER_PULSE_DECAY = 0.006;                // user-snap pulses fade ~3× faster — cleaner ripples
      const RELEASE_FACTOR   = 0.7;                  // compensates for amp*0.7*2 pulse-split doubling at age=0 (0.7×1.4≈1.0)
      // Mobile gets a shorter cooldown: touch is naturally slower than mouse so resonance is
      // less of an issue, and a long cooldown causes finger drags to feel skippy/non-responsive.
      const SNAP_COOLDOWN_WT = isTouchDevice ? 4 : 10;  // ~45ms mobile / ~110ms desktop

      function compY(gl: GLayer, x: number, t: number): number {
        let y = 0;
        for (const [A, k, w, phi] of gl.comps) y += A * Math.cos(k * x + w * t + phi);
        return y;
      }

      // Squared cosine bell: smooth but steep sides — tent-like without the spike
      function bell(dx: number, hw: number): number {
        if (Math.abs(dx) >= hw) return 0;
        const b = 0.5 * (1 + Math.cos(Math.PI * dx / hw));
        return b * b;
      }

      function bowDeform(st: BowState, x: number, t: number): number {
        let result = 0;

        // Current pull deformation
        if (st.engaged && Math.abs(st.pullAmt) >= 0.3) {
          const dx = x - st.pullX;
          if (Math.abs(dx) < BOW_HW) result += st.pullAmt * bell(dx, BOW_HW);
        }

        // All active pulses — each travels independently
        for (const p of st.pulses) {
          const age = t - p.releaseT;
          const rise = p.riseT ? Math.min(age / p.riseT, 1) : 1; // ease in from zero
          const amp = p.releaseAmt * rise * Math.exp(-age * (p.decay ?? PULSE_DECAY));
          if (Math.abs(amp) < 0.3) continue;
          const hw = (p.hw0 ?? PULSE_HW0) + age * 1.4;
          const pSpeed = p.speed ?? PULSE_SPEED;
          for (const cx of [p.pullX - pSpeed * age, p.pullX + pSpeed * age]) {
            const dx = x - cx;
            if (Math.abs(dx) < hw) result += amp * 0.7 * bell(dx, hw);
          }
        }

        return result;
      }

      // Pulse-only deformation — used for the interaction surface hit-test so the
      // engaged-pull doesn't feed back into the surface it's measuring. Without this,
      // surf ≈ my for all engaged layers → they visually cluster at the cursor, and
      // any mouse movement causes a snap/oscillation (new_pullAmt = D - old_pullAmt).
      function bowDeformPulses(st: BowState, x: number, t: number): number {
        let result = 0;
        for (const p of st.pulses) {
          const age = t - p.releaseT;
          const rise = p.riseT ? Math.min(age / p.riseT, 1) : 1;
          const amp = p.releaseAmt * rise * Math.exp(-age * (p.decay ?? PULSE_DECAY));
          if (Math.abs(amp) < 0.3) continue;
          const hw = (p.hw0 ?? PULSE_HW0) + age * 1.4;
          const pSpeed = p.speed ?? PULSE_SPEED;
          for (const cx of [p.pullX - pSpeed * age, p.pullX + pSpeed * age]) {
            const dx = x - cx;
            if (Math.abs(dx) < hw) result += amp * 0.7 * bell(dx, hw);
          }
        }
        return result;
      }

      function waveY(gl: GLayer, li: number, x: number, t: number): number {
        return compY(gl, x, t) + bowDeform(bowStates[li], x, t);
      }

      const NW = 700;
      function drawGLayer(gl: GLayer, li: number) {
        const isNight = document.documentElement.classList.contains('night');
        const bY   = gl.baseRatio * wH;
        const step = wW / (NW - 1);
        wctx.beginPath();
        let prevY = bY + waveY(gl, li, 0, wT);
        wctx.moveTo(0, prevY);
        for (let i = 1; i < NW; i++) {
          const x0 = (i - 1) * step, x1 = i * step;
          const y1 = bY + waveY(gl, li, x1, wT);
          wctx.quadraticCurveTo(x0, prevY, (x0 + x1) / 2, (prevY + y1) / 2);
          prevY = y1;
        }
        // Close polygon: fillUp closes up to y=0 (sky), default closes down to y=wH (water)
        if (gl.fillUp) {
          wctx.lineTo(wW, 0);
          wctx.lineTo(0, 0);
        } else {
          wctx.lineTo(wW, wH);
          wctx.lineTo(0, wH);
        }
        wctx.closePath();
        wctx.fillStyle = isNight ? gl.nightColor : gl.dayColor;
        wctx.fill();
      }

      // Snap-release helper — pushes a small, fast-decaying pulse with amplitude
      // AND width matched to the held bell so the deformation doesn't visibly
      // "teleport" wider at the snap moment. Sets a brief cooldown so the band
      // can't immediately re-engage and snap again, which would stack pulses
      // at the same x and visually multiply the amplitude.
      function releaseSnap(st: BowState, snapAmt: number) {
        st.pulses.push({
          pullX: st.pullX,
          releaseAmt: snapAmt * RELEASE_FACTOR,
          releaseT: wT,
          decay: USER_PULSE_DECAY,
          hw0: BOW_HW,                  // start at the same width as the engaged bell — no width jump
        });
        st.engaged = false;
        st.pullAmt = 0;
        st.cooldownUntil = wT + SNAP_COOLDOWN_WT;
      }

      // Wave interaction — single-band engagement, clamped pull, gentle release.
      // zenOnly layers (sky aurora) are skipped entirely when zen mode is off so
      // the cursor doesn't engage invisible bands in the sky area.
      function handleWaveInteraction(mx: number, my: number) {
        const isZen = document.documentElement.classList.contains('zen-mode');
        // Pass 1: find the band whose natural surface is closest to the cursor.
        // Only one band engages at a time; others release as small ripples.
        let closestIdx = -1;
        let closestDist = Infinity;
        const surfs: number[] = [];
        gLayers.forEach((gl, i) => {
          if (gl.zenOnly && (!SKY_WAVES_ENABLED || !isZen)) { surfs.push(NaN); return; }
          const st = bowStates[i];
          const surf = gl.baseRatio * wH + compY(gl, mx, wT) + bowDeformPulses(st, mx, wT);
          surfs.push(surf);
          const d = Math.abs(my - surf);
          if (d < closestDist) { closestDist = d; closestIdx = i; }
        });

        gLayers.forEach((gl, i) => {
          if (gl.zenOnly && (!SKY_WAVES_ENABLED || !isZen)) return;
          const st   = bowStates[i];
          const surf = surfs[i];
          const rawPull = my - surf;

          if (st.engaged) {
            // If a different band became the closest, gently release this one.
            if (i !== closestIdx) { releaseSnap(st, st.pullAmt); return; }
            st.pullX = mx;
            // Clamp visual pull so the wave can't stretch into a mountain on fast moves
            st.pullAmt = Math.max(-SNAP_DIST, Math.min(SNAP_DIST, rawPull));
            // Snap when the raw cursor distance crosses the threshold
            if (Math.abs(rawPull) >= SNAP_DIST) releaseSnap(st, st.pullAmt);
          } else if (i === closestIdx && closestDist <= ENGAGE_DIST && wT >= st.cooldownUntil) {
            // Engage only the single closest band, and only if its post-snap cooldown has elapsed
            st.engaged = true; st.pullX = mx; st.pullAmt = 0;
          }
        });
      }

      // Mouse
      let lastMX = -1;
      document.addEventListener('mousemove', (e) => {
        if (lastMX < 0) { lastMX = e.clientX; return; }
        handleWaveInteraction(e.clientX, e.clientY);
        lastMX = e.clientX;
      });

      // Touch — same bowstring mechanic as mouse
      let lastTX = -1, lastTY = -1;

      document.addEventListener('touchstart', (e) => {
        const t = e.touches[0];
        lastTX = t.clientX; lastTY = t.clientY;
        handleWaveInteraction(t.clientX, t.clientY);
      }, { passive: true });

      document.addEventListener('touchmove', (e) => {
        const t = e.touches[0];
        handleWaveInteraction(t.clientX, t.clientY);
        lastTX = t.clientX; lastTY = t.clientY;
      }, { passive: true });

      document.addEventListener('touchend', () => {
        // Release any engaged lines on finger lift — gentle pulse, not a snap punch
        bowStates.forEach(st => { if (st.engaged) releaseSnap(st, st.pullAmt); });
      }, { passive: true });

      function animateWaves() {
        // Prune dead pulses from every layer's pool
        bowStates.forEach(st => {
          st.pulses = st.pulses.filter(p => {
            const age = wT - p.releaseT;
            return Math.abs(p.releaseAmt * Math.exp(-age * (p.decay ?? PULSE_DECAY))) >= 0.3;
          });
        });
        wctx.clearRect(0, 0, wW, wH);
        wT = (performance.now() - wStartTime) * 0.09; // +50% speed vs 60fps baseline
        const isZen = document.documentElement.classList.contains('zen-mode');
        gLayers.forEach((l, li) => {
          if (l.zenOnly && !isZen) return; // hide aurora bands outside zen mode
          drawGLayer(l, li);
        });
        requestAnimationFrame(animateWaves);
      }
      animateWaves();

      // When zen mode exits, clear any engagement/pulses on the aurora bands so
      // they don't carry hidden state into the next activation.
      const zenObserver = new MutationObserver(() => {
        const isZen = document.documentElement.classList.contains('zen-mode');
        if (!isZen) {
          gLayers.forEach((gl, i) => {
            if (!gl.zenOnly) return;
            const st = bowStates[i];
            st.engaged = false;
            st.pullAmt = 0;
            st.pulses = [];
            st.cooldownUntil = 0;
          });
        }
      });
      zenObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

      // Expose wave ripple so solar explosion can disturb the river.
      // Sky aurora bands also catch the shockwave, but inverted (pushed upward)
      // since the energy is radiating outward from the sun in the sky.
      (window as any).triggerWaveRipple = () => {
        const ox = wW * 0.84; // directly below the sun (top-right)
        let riverIdx = 0;
        bowStates.forEach((st, i) => {
          if (gLayers[i].zenOnly) {
            if (!SKY_WAVES_ENABLED) return; // skip sky ripples while sky bands are off
            // Sky band — push upward (negative pull) with a gentler amplitude
            const skyIdx = i - 5; // 0..4 within the sky stack
            st.pulses.push({ pullX: ox, releaseAmt: -(70 + skyIdx * 10), releaseT: wT + skyIdx * 2, hw0: 1950, riseT: 14 });
            st.pulses.push({ pullX: ox, releaseAmt: -(36 + skyIdx * 6), releaseT: wT + skyIdx * 2 + 27, hw0: 1140, riseT: 10 });
          } else {
            // River band — original downward shockwave
            st.pulses.push({ pullX: ox, releaseAmt: 95 + riverIdx * 15, releaseT: wT + riverIdx * 2, hw0: 1950, riseT: 14 });
            st.pulses.push({ pullX: ox, releaseAmt: 48 + riverIdx * 8, releaseT: wT + riverIdx * 2 + 27, hw0: 1140, riseT: 10 });
            riverIdx++;
          }
        });
      };

      // Periodic tidal wave — river-only sweep across the water
      let tidalDir = 1;
      (window as any).triggerTidalWave = () => {
        const ox = tidalDir > 0 ? -300 : wW + 300; // start off-screen left or right
        tidalDir = -tidalDir;
        let riverIdx = 0;
        bowStates.forEach((st, i) => {
          if (gLayers[i].zenOnly) return; // sky bands stay still during tidal sweep
          st.pulses.push({ pullX: ox, releaseAmt: -(280 + riverIdx * 35), releaseT: wT + riverIdx * 4, hw0: 380, riseT: 22, decay: 0.000225 });
          riverIdx++;
        });
      };

      // Hide nav on scroll down, reveal on scroll up
      const navEl = document.querySelector('nav') as HTMLElement;
      let lastScrollY = 0;
      window.addEventListener('scroll', () => {
        const y = window.scrollY;
        if (y > lastScrollY && y > 80) {
          navEl?.classList.add('nav-hidden');
        } else {
          navEl?.classList.remove('nav-hidden');
        }
        lastScrollY = y;
      }, { passive: true });

      // Night mode toggle — bind all buttons with class .mode-toggle
      const modeToggles = document.querySelectorAll('.mode-toggle');
      function updateToggleIcons() {
        const isNight = document.documentElement.classList.contains('night');
        modeToggles.forEach(btn => btn.textContent = isNight ? '○' : '☽');
      }
      updateToggleIcons();
      modeToggles.forEach(btn => btn.addEventListener('click', () => {
        const isNight = document.documentElement.classList.toggle('night');
        localStorage.setItem('night-mode', String(isNight));
        updateToggleIcons();
      }));
    </script>
  </body>
</html>
