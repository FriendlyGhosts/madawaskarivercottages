---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Madawaska River Cottages',
  description = 'Four private riverside cottages on the Madawaska River. Escape the ordinary.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Josefin+Slab:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel+Decorative:wght@400;700&family=Uncial+Antiqua&family=Pirata+One&family=Fondamento:ital@0;1&family=Metamorphous&family=Caesar+Dressing&family=Mystery+Quest&family=Cormorant:ital,wght@0,300;0,400;1,300&family=Cormorant+Unicase:wght@300;400;500&family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;1,6..96,400&family=Poiret+One&family=Inter:wght@300;400;500&display=swap" />
    <script is:inline>if(localStorage.getItem('night-mode')==='true')document.documentElement.classList.add('night');</script>
  </head>
  <body>
    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>
    <canvas id="wave-canvas" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none;"></canvas>

    <slot />

    <script>
      // Custom cursor
      const dot = document.getElementById('cursor-dot')!;
      const ring = document.getElementById('cursor-ring')!;

      let ringX = 0, ringY = 0;
      let mouseX = 0, mouseY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        dot.style.left = mouseX + 'px';
        dot.style.top = mouseY + 'px';
      });

      function animateRing() {
        ringX += (mouseX - ringX) * 0.12;
        ringY += (mouseY - ringY) * 0.12;
        ring.style.left = ringX + 'px';
        ring.style.top = ringY + 'px';
        requestAnimationFrame(animateRing);
      }
      animateRing();

      // Hover effect on interactive elements
      const hoverTargets = document.querySelectorAll('a, button, [data-hover]');
      hoverTargets.forEach(el => {
        el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
        el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
      });

      // Scroll reveal
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.12 });

      reveals.forEach(el => observer.observe(el));

      // Gerstner sum-of-cosines waves + per-layer bowstring surface tension
      const waveCanvas = document.getElementById('wave-canvas') as HTMLCanvasElement;
      const wctx = waveCanvas.getContext('2d')!;
      let wW = 0, wH = 0;

      function wResize() {
        const dpr = window.devicePixelRatio || 1;
        wW = window.innerWidth;
        wH = window.innerHeight;
        waveCanvas.width  = Math.round(wW * dpr);
        waveCanvas.height = Math.round(wH * dpr);
        wctx.setTransform(dpr, 0, 0, dpr, 0, 0); // scale once, resets on each call
      }
      window.addEventListener('resize', wResize);
      wResize();

      let wT = 0;
      const wStartTime = performance.now();

      type WComp = [number, number, number, number]; // [A, k, ω, φ]
      function wc(A: number, lambda: number, speed: number, phi: number): WComp {
        const k = (2 * Math.PI) / lambda;
        return [A, k, k * speed, phi];
      }

      interface GLayer { baseRatio: number; comps: WComp[]; dayColor: string; nightColor: string; }
      const gLayers: GLayer[] = [
        { baseRatio: 0.50, dayColor: 'rgba(28,80,110,0.06)',  nightColor: 'rgba(15,55,45,0.14)',
          comps: [wc(10,760,1.8,0.00), wc(4.5,440,1.4,1.10), wc(2.0,230,1.0,2.30), wc(0.8,115,0.7,0.55)] },
        { baseRatio: 0.60, dayColor: 'rgba(28,80,110,0.09)',  nightColor: 'rgba(15,55,45,0.20)',
          comps: [wc(9,690,1.9,0.80), wc(4.0,400,1.5,2.00), wc(1.8,210,1.1,0.90), wc(0.9,105,0.8,1.70)] },
        { baseRatio: 0.69, dayColor: 'rgba(28,80,110,0.12)',  nightColor: 'rgba(15,55,45,0.26)',
          comps: [wc(8,720,1.7,1.60), wc(3.5,420,1.3,0.40), wc(2.2,240,0.9,2.80), wc(1.0,120,0.6,1.20)] },
        { baseRatio: 0.77, dayColor: 'rgba(28,80,110,0.15)',  nightColor: 'rgba(15,55,45,0.33)',
          comps: [wc(7,680,2.0,2.40), wc(3.0,380,1.6,0.70), wc(1.6,200,1.2,1.80), wc(0.7,100,0.9,3.10)] },
        { baseRatio: 0.84, dayColor: 'rgba(28,80,110,0.19)',  nightColor: 'rgba(15,55,45,0.40)',
          comps: [wc(6,640,2.1,3.20), wc(2.5,360,1.7,1.50), wc(1.4,190,1.3,0.30), wc(0.6,95,1.0,2.10)] },
      ];

      // Per-layer bowstring state — supports multiple concurrent pulses
      interface Pulse { pullX: number; releaseAmt: number; releaseT: number; hw0?: number; riseT?: number; decay?: number; speed?: number; }
      interface BowState { engaged: boolean; pullX: number; pullAmt: number; pulses: Pulse[]; }
      const bowStates: BowState[] = gLayers.map(() => ({
        engaged: false, pullX: 0, pullAmt: 0, pulses: [],
      }));
      const isTouchDevice = navigator.maxTouchPoints > 0;
      const ENGAGE_DIST = isTouchDevice ? 22 : 11;
      const SNAP_DIST   = isTouchDevice ? 28 : 62;
      const BOW_HW      = 85;

      const PULSE_SPEED = 2.2;
      const PULSE_DECAY = 0.0018;
      const PULSE_HW0   = 110;

      function compY(gl: GLayer, x: number, t: number): number {
        let y = 0;
        for (const [A, k, w, phi] of gl.comps) y += A * Math.cos(k * x + w * t + phi);
        return y;
      }

      // Squared cosine bell: smooth but steep sides — tent-like without the spike
      function bell(dx: number, hw: number): number {
        if (Math.abs(dx) >= hw) return 0;
        const b = 0.5 * (1 + Math.cos(Math.PI * dx / hw));
        return b * b;
      }

      function bowDeform(st: BowState, x: number, t: number): number {
        let result = 0;

        // Current pull deformation
        if (st.engaged && Math.abs(st.pullAmt) >= 0.3) {
          const dx = x - st.pullX;
          if (Math.abs(dx) < BOW_HW) result += st.pullAmt * bell(dx, BOW_HW);
        }

        // All active pulses — each travels independently
        for (const p of st.pulses) {
          const age = t - p.releaseT;
          const rise = p.riseT ? Math.min(age / p.riseT, 1) : 1; // ease in from zero
          const amp = p.releaseAmt * rise * Math.exp(-age * (p.decay ?? PULSE_DECAY));
          if (Math.abs(amp) < 0.3) continue;
          const hw = (p.hw0 ?? PULSE_HW0) + age * 1.4;
          const pSpeed = p.speed ?? PULSE_SPEED;
          for (const cx of [p.pullX - pSpeed * age, p.pullX + pSpeed * age]) {
            const dx = x - cx;
            if (Math.abs(dx) < hw) result += amp * 0.7 * bell(dx, hw);
          }
        }

        return result;
      }

      // Pulse-only deformation — used for the interaction surface hit-test so the
      // engaged-pull doesn't feed back into the surface it's measuring. Without this,
      // surf ≈ my for all engaged layers → they visually cluster at the cursor, and
      // any mouse movement causes a snap/oscillation (new_pullAmt = D - old_pullAmt).
      function bowDeformPulses(st: BowState, x: number, t: number): number {
        let result = 0;
        for (const p of st.pulses) {
          const age = t - p.releaseT;
          const rise = p.riseT ? Math.min(age / p.riseT, 1) : 1;
          const amp = p.releaseAmt * rise * Math.exp(-age * (p.decay ?? PULSE_DECAY));
          if (Math.abs(amp) < 0.3) continue;
          const hw = (p.hw0 ?? PULSE_HW0) + age * 1.4;
          const pSpeed = p.speed ?? PULSE_SPEED;
          for (const cx of [p.pullX - pSpeed * age, p.pullX + pSpeed * age]) {
            const dx = x - cx;
            if (Math.abs(dx) < hw) result += amp * 0.7 * bell(dx, hw);
          }
        }
        return result;
      }

      function waveY(gl: GLayer, li: number, x: number, t: number): number {
        return compY(gl, x, t) + bowDeform(bowStates[li], x, t);
      }

      const NW = 700;
      function drawGLayer(gl: GLayer, li: number) {
        const isNight = document.documentElement.classList.contains('night');
        const bY   = gl.baseRatio * wH;
        const step = wW / (NW - 1);
        wctx.beginPath();
        let prevY = bY + waveY(gl, li, 0, wT);
        wctx.moveTo(0, prevY);
        for (let i = 1; i < NW; i++) {
          const x0 = (i - 1) * step, x1 = i * step;
          const y1 = bY + waveY(gl, li, x1, wT);
          wctx.quadraticCurveTo(x0, prevY, (x0 + x1) / 2, (prevY + y1) / 2);
          prevY = y1;
        }
        wctx.lineTo(wW, wH);
        wctx.lineTo(0, wH);
        wctx.closePath();
        wctx.fillStyle = isNight ? gl.nightColor : gl.dayColor;
        wctx.fill();
      }

      // Shared wave interaction — mouse and touch
      function handleWaveInteraction(mx: number, my: number) {
        // On mobile, limit to one NEW engagement per frame so a large pulse doesn't
        // grab every band simultaneously via a single touch point.
        let mobileEngaged = false;
        gLayers.forEach((gl, i) => {
          const st = bowStates[i];
          const surf = gl.baseRatio * wH + compY(gl, mx, wT) + bowDeform(st, mx, wT);
          if (st.engaged) {
            st.pullX   = mx;
            st.pullAmt = my - surf;
            if (Math.abs(st.pullAmt) >= SNAP_DIST) {
              // Push a new pulse into the pool — old ones keep travelling
              st.pulses.push({ pullX: st.pullX, releaseAmt: st.pullAmt, releaseT: wT });
              st.engaged = false;
              st.pullAmt = 0;
            }
          } else if (Math.abs(my - surf) <= ENGAGE_DIST) {
            if (isTouchDevice && mobileEngaged) return;
            st.engaged = true; st.pullX = mx; st.pullAmt = 0;
            if (isTouchDevice) mobileEngaged = true;
          }
        });
      }

      // Mouse
      let lastMX = -1;
      document.addEventListener('mousemove', (e) => {
        if (lastMX < 0) { lastMX = e.clientX; return; }
        handleWaveInteraction(e.clientX, e.clientY);
        lastMX = e.clientX;
      });

      // Touch — same bowstring mechanic as mouse
      let lastTX = -1, lastTY = -1;

      document.addEventListener('touchstart', (e) => {
        const t = e.touches[0];
        lastTX = t.clientX; lastTY = t.clientY;
        handleWaveInteraction(t.clientX, t.clientY);
      }, { passive: true });

      document.addEventListener('touchmove', (e) => {
        const t = e.touches[0];
        handleWaveInteraction(t.clientX, t.clientY);
        lastTX = t.clientX; lastTY = t.clientY;
      }, { passive: true });

      document.addEventListener('touchend', () => {
        // Snap any engaged lines on finger lift — push into pool
        bowStates.forEach(st => {
          if (st.engaged) {
            st.pulses.push({ pullX: st.pullX, releaseAmt: st.pullAmt, releaseT: wT });
            st.engaged = false;
            st.pullAmt = 0;
          }
        });
      }, { passive: true });

      function animateWaves() {
        // Prune dead pulses from every layer's pool
        bowStates.forEach(st => {
          st.pulses = st.pulses.filter(p => {
            const age = wT - p.releaseT;
            return Math.abs(p.releaseAmt * Math.exp(-age * (p.decay ?? PULSE_DECAY))) >= 0.3;
          });
        });
        wctx.clearRect(0, 0, wW, wH);
        wT = (performance.now() - wStartTime) * 0.09; // +50% speed vs 60fps baseline
        gLayers.forEach((l, li) => drawGLayer(l, li));
        requestAnimationFrame(animateWaves);
      }
      animateWaves();

      // Expose wave ripple so solar explosion can disturb the river
      (window as any).triggerWaveRipple = () => {
        const ox = wW * 0.84; // directly below the sun (top-right)
        bowStates.forEach((st, i) => {
          // Primary shockwave — fast deep press, very wide bell (3× wider than original)
          st.pulses.push({ pullX: ox, releaseAmt: 95 + i * 15, releaseT: wT + i * 2, hw0: 1950, riseT: 14 });
          // Secondary trailing ripple — arrives ~0.45s later, also 3× wider
          st.pulses.push({ pullX: ox, releaseAmt: 48 + i * 8, releaseT: wT + i * 2 + 27, hw0: 1140, riseT: 10 });
        });
      };

      // Periodic tidal wave — large swell that sweeps across the river in alternating directions
      let tidalDir = 1;
      (window as any).triggerTidalWave = () => {
        const ox = tidalDir > 0 ? -300 : wW + 300; // start off-screen left or right
        tidalDir = -tidalDir;
        bowStates.forEach((st, i) => {
          st.pulses.push({ pullX: ox, releaseAmt: -(280 + i * 35), releaseT: wT + i * 4, hw0: 380, riseT: 22, decay: 0.000225 });
        });
      };

      // Hide nav on scroll down, reveal on scroll up
      const navEl = document.querySelector('nav') as HTMLElement;
      let lastScrollY = 0;
      window.addEventListener('scroll', () => {
        const y = window.scrollY;
        if (y > lastScrollY && y > 80) {
          navEl?.classList.add('nav-hidden');
        } else {
          navEl?.classList.remove('nav-hidden');
        }
        lastScrollY = y;
      }, { passive: true });

      // Night mode toggle — bind all buttons with class .mode-toggle
      const modeToggles = document.querySelectorAll('.mode-toggle');
      function updateToggleIcons() {
        const isNight = document.documentElement.classList.contains('night');
        modeToggles.forEach(btn => btn.textContent = isNight ? '○' : '☽');
      }
      updateToggleIcons();
      modeToggles.forEach(btn => btn.addEventListener('click', () => {
        const isNight = document.documentElement.classList.toggle('night');
        localStorage.setItem('night-mode', String(isNight));
        updateToggleIcons();
      }));
    </script>
  </body>
</html>
